---
/**
 * Driver Dashboard Content Component
 *
 * Driver-specific dashboard with current delivery, available orders queue, and stats.
 *
 * @component content-container/Driver/DriverDashboard
 * @version 0.1.0
 */

import DriverDashboardComponent from '../../components/driver/DriverDashboardComponent.tsx';
import type { DriverDashboardPageData } from '../../lib/data/appPageData';

interface Props {
  data: DriverDashboardPageData;
}

const { data } = Astro.props;

// Debug logging
console.log('[DriverDashboard.astro] Server-side data:', {
  driverId: data.driver?.id,
  driverStatus: data.driver?.status,
  activeDeliveriesCount: data.activeDeliveries?.length || 0,
  availableOrdersCount: data.availableOrders?.length,
  stats: data.stats,
  userId: data.userId,
  timestamp: new Date().toISOString()
});
---

<DriverDashboardComponent
  client:load
  driver={data.driver}
  activeDeliveries={data.activeDeliveries || []}
  availableOrders={data.availableOrders || []}
  stats={data.stats}
  userId={data.userId}
/>
