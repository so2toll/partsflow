---
/**
 * Components Library Content Component (SuperAdmin Only)
 *
 * A showcase of reusable UI components following the Stitch design system.
 * Features Electric Lime (#DFFF00) accents, DM Sans typography, and 8px spacing rhythm.
 *
 * @component Admin/ComponentsLibrary
 * @access SuperAdmin only
 */

import Layout from '../../layouts/Layout.astro';

interface Props {
  data: any;
  userRole: string;
  userId: string;
}

const { data, userRole, userId } = Astro.props;
---

<Layout title="Components Library">
  <div class="components-library">
    <!-- Header -->
    <div class="header">
      <div class="dev-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        SUPERADMIN ONLY
      </div>
    </div>

    <!-- Page Title -->
    <h1>Components Library</h1>
    <p class="page-description">A showcase of reusable UI components following the Stitch design system. Features Electric Lime (#DFFF00) accents, DM Sans typography, and 8px spacing rhythm.</p>

    <!-- Design Tokens -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Design Tokens</text>
      </h2>

      <div class="subsection">
        <h3 class="subsection-title">Colors</h3>
        <div class="color-grid">
          <div class="color-swatch">
            <div class="color-box" style="background: #dfff00;"></div>
            <div class="color-info">
              <div class="color-name">Electric Lime (Primary)</div>
              <div class="color-hex">#DFFF00</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #f9f9f9;"></div>
            <div class="color-info">
              <div class="color-name">Surface</div>
              <div class="color-hex">#F9F9F9</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #ffffff; border: 1px solid #e2e2e2;"></div>
            <div class="color-info">
              <div class="color-name">Surface Container</div>
              <div class="color-hex">#FFFFFF</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #1a1c1c;"></div>
            <div class="color-info">
              <div class="color-name">On Surface</div>
              <div class="color-hex">#1A1C1C</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #666666;"></div>
            <div class="color-info">
              <div class="color-name">Secondary Text</div>
              <div class="color-hex">#666666</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #22c55e;"></div>
            <div class="color-info">
              <div class="color-name">Success</div>
              <div class="color-hex">#22C55E</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #f59e0b;"></div>
            <div class="color-info">
              <div class="color-name">Warning</div>
              <div class="color-hex">#F59E0B</div>
            </div>
          </div>
          <div class="color-swatch">
            <div class="color-box" style="background: #ef4444;"></div>
            <div class="color-info">
              <div class="color-name">Danger</div>
              <div class="color-hex">#EF4444</div>
            </div>
          </div>
        </div>
      </div>

      <div class="subsection">
        <h3 class="subsection-title">Typography</h3>
        <div class="typography-showcase">
          <div class="text-display-lg">Display Large - 64px</div>
          <div class="text-headline-lg">Headline Large - 32px</div>
          <div class="text-headline-md">Headline Medium - 24px</div>
          <div class="text-body-lg">Body Large - 18px - The quick brown fox jumps over the lazy dog.</div>
          <div class="text-body-md">Body Medium - 16px - The quick brown fox jumps over the lazy dog.</div>
          <div class="text-label-md">Label Medium - 14px</div>
          <div class="text-label-sm">Label Small - 12px</div>
        </div>
      </div>

      <div class="subsection">
        <h3 class="subsection-title">Spacing (8px Rhythm)</h3>
        <div class="spacing-showcase">
          <div class="spacing-item">
            <div class="spacing-box" style="width: 4px; height: 4px; background: #dfff00;"></div>
            <span>xs: 4px</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-box" style="width: 8px; height: 8px; background: #dfff00;"></div>
            <span>base: 8px</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-box" style="width: 12px; height: 12px; background: #dfff00;"></div>
            <span>sm: 12px</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-box" style="width: 24px; height: 24px; background: #dfff00;"></div>
            <span>md: 24px</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-box" style="width: 48px; height: 48px; background: #dfff00;"></div>
            <span>lg: 48px</span>
          </div>
          <div class="spacing-item">
            <div class="spacing-box" style="width: 80px; height: 80px; background: #dfff00;"></div>
            <span>xl: 80px</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Buttons -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Buttons</text>
      </h2>

      <div class="subsection">
        <h3 class="subsection-title">Button Variants</h3>
        <div class="demo-card">
          <div class="demo-row">
            <button class="btn btn-primary">Primary</button>
            <button class="btn btn-secondary">Secondary</button>
            <button class="btn btn-tertiary">Tertiary</button>
            <button class="btn btn-ghost">Ghost</button>
            <button class="btn btn-outline">Outline</button>
          </div>
          <div class="code-block">&lt;Button variant="primary"&gt;Primary&lt;/Button&gt;
&lt;Button variant="secondary"&gt;Secondary&lt;/Button&gt;
&lt;Button variant="tertiary"&gt;Tertiary&lt;/Button&gt;
&lt;Button variant="ghost"&gt;Ghost&lt;/Button&gt;
&lt;Button variant="outline"&gt;Outline&lt;/Button&gt;</div>
        </div>
      </div>

      <div class="subsection">
        <h3 class="subsection-title">Button Sizes</h3>
        <div class="demo-card">
          <div class="demo-row">
            <button class="btn btn-primary btn-sm">Small</button>
            <button class="btn btn-primary">Default</button>
            <button class="btn btn-primary btn-lg">Large</button>
          </div>
          <div class="code-block">&lt;Button size="sm"&gt;Small&lt;/Button&gt;
&lt;Button size="default"&gt;Default&lt;/Button&gt;
&lt;Button size="lg"&gt;Large&lt;/Button&gt;</div>
        </div>
      </div>
    </div>

    <!-- Input Fields -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Input Fields</text>
      </h2>

      <div class="subsection">
        <h3 class="subsection-title">Basic Inputs</h3>
        <div class="demo-card">
          <div class="input-demo">
            <input type="text" class="input" placeholder="Enter your name..." />
            <input type="email" class="input" placeholder="email@example.com" />
            <input type="password" class="input" placeholder="Password" />
          </div>
          <div class="code-block">&lt;Input type="text" placeholder="Enter your name..." /&gt;</div>
        </div>
      </div>
    </div>

    <!-- Cards -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Cards</text>
      </h2>

      <div class="component-grid">
        <div class="demo-card">
          <h4>Basic Card</h4>
          <p>Cards are borderless with ambient shadows and 16px border radius.</p>
          <button class="btn btn-primary btn-sm">Action</button>
        </div>

        <div class="demo-card">
          <div class="card-header-inline">
            <div>
              <h4>Project Alpha</h4>
              <p class="card-meta">Updated 2h ago</p>
            </div>
            <span class="badge badge-primary">Active</span>
          </div>
          <p>AI-powered video analysis pipeline with real-time processing.</p>
          <div class="card-actions">
            <button class="btn btn-secondary btn-sm">Edit</button>
            <button class="btn btn-ghost btn-sm">Delete</button>
          </div>
        </div>

        <div class="demo-card">
          <h4 class="stat-number">1,234</h4>
          <p>Total Projects</p>
          <div class="stat-trend">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            +12.5% from last month
          </div>
        </div>
      </div>
    </div>

    <!-- Badges -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Badges & Tags</text>
      </h2>

      <div class="subsection">
        <h3 class="subsection-title">Badge Variants</h3>
        <div class="demo-card">
          <div class="demo-row">
            <span class="badge badge-default">Default</span>
            <span class="badge badge-primary">Primary</span>
            <span class="badge badge-success">Success</span>
            <span class="badge badge-warning">Warning</span>
            <span class="badge badge-danger">Danger</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Progress -->
    <div class="section">
      <h2 class="section-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><text x="40" y="24" fill="currentColor">Progress Bars</text>
      </h2>

      <div class="subsection">
        <h3 class="subsection-title">Progress States</h3>
        <div class="demo-card">
          <div class="progress-demo">
            <div class="progress-item">
              <div class="progress-labels">
                <span>Processing...</span>
                <span>25%</span>
              </div>
              <div class="progress">
                <div class="progress-value" style="transform: translateX(-75%);"></div>
              </div>
            </div>
            <div class="progress-item">
              <div class="progress-labels">
                <span>Almost there...</span>
                <span>75%</span>
              </div>
              <div class="progress">
                <div class="progress-value" style="transform: translateX(-25%);"></div>
              </div>
            </div>
            <div class="progress-item">
              <div class="progress-labels">
                <span>Complete!</span>
                <span>100%</span>
              </div>
              <div class="progress">
                <div class="progress-value" style="transform: translateX(0%);"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Components Library - Stitch Design System - Built with Tailwind CSS + Astro</p>
      <p class="footer-meta">Electric Lime #DFFF00 · DM Sans · 8px Spacing Rhythm · SuperAdmin Only</p>
    </div>
  </div>
</Layout>

<style>
  .components-library {
    max-width: 1440px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  .header {
    margin-bottom: 24px;
  }

  .dev-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #dfff00;
    color: #000000;
    padding: 6px 12px;
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 700;
  }

  h1 {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 16px 0;
    color: #1a1c1c;
  }

  .page-description {
    font-size: 18px;
    line-height: 1.6;
    color: #666666;
    max-width: 600px;
    margin: 0 0 48px 0;
  }

  .section {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 24px 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title svg {
    color: #dfff00;
  }

  .subsection {
    margin-bottom: 32px;
  }

  .subsection-title {
    font-size: 18px;
    font-weight: 500;
    margin: 0 0 16px 0;
    color: #474832;
  }

  /* Color Grid */
  .color-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .color-swatch {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
  }

  .color-box {
    height: 80px;
    width: 100%;
  }

  .color-info {
    background: white;
    padding: 12px;
  }

  .color-name {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 4px 0;
  }

  .color-hex {
    font-size: 12px;
    color: #666666;
    font-family: monospace;
    margin: 0;
  }

  /* Typography */
  .typography-showcase {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .text-display-lg {
    font-size: 64px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .text-headline-lg {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .text-headline-md {
    font-size: 24px;
    font-weight: 500;
    line-height: 1.3;
  }

  .text-body-lg {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
  }

  .text-body-md {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
  }

  .text-label-md {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .text-label-sm {
    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;
  }

  /* Spacing */
  .spacing-showcase {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .spacing-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Demo Card */
  .demo-card {
    background: white;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.2s;
  }

  .demo-card:hover {
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }

  .demo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin: 0 0 16px 0;
  }

  .input-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 400px;
  }

  .code-block {
    background: #1a1c1c;
    color: #e2e2e2;
    padding: 16px;
    border-radius: 8px;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', monospace;
    font-size: 14px;
    overflow-x: auto;
    margin: 16px 0 0 0;
    white-space: pre;
  }

  /* Component Grid */
  .component-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .demo-card h4 {
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 12px 0;
  }

  .demo-card p {
    color: #666666;
    font-size: 14px;
    margin: 0 0 16px 0;
  }

  .card-header-inline {
    display: flex;
    align-items: start;
    justify-content: space-between;
    margin: 0 0 16px 0;
  }

  .card-header-inline h4 {
    margin: 0;
  }

  .card-meta {
    color: #666666;
    font-size: 12px;
    margin: 0;
  }

  .card-actions {
    display: flex;
    gap: 8px;
  }

  .stat-number {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 8px 0;
  }

  .stat-trend {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #22c55e;
    font-size: 14px;
    font-weight: 500;
  }

  /* Progress */
  .progress-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .progress-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .progress-labels {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
  }

  /* Footer */
  .footer {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid #e2e2e2;
    color: #666666;
    font-size: 14px;
  }

  .footer p {
    margin: 0;
  }

  .footer-meta {
    margin-top: 8px;
    font-size: 12px;
  }
</style>
