---
/**
 * Upload Content Component - Video AI Edit Mode
 *
 * Provides a drag-and-drop video upload interface for Edit Mode.
 * After successful upload, redirects to Edit Mode with the uploaded video.
 *
 * Features:
 * - Drag and drop file upload
 * - File type validation (mp4, mov, avi)
 * - File size validation (max 500MB)
 * - Upload progress tracking
 * - Automatic redirect to edit page after upload
 *
 * @component App/Upload
 */

import Layout from '../../layouts/Layout.astro';

interface Props {
  data: any;
  userRole: string;
  userId: string;
}

const { data, userRole, userId } = Astro.props;
---

<Layout title="Upload Video">
  <div class="upload-page p-6">
    <main class="main-content max-w-4xl mx-auto">

      <!-- Page Header -->
      <div class="page-header mb-8">
        <h1 class="page-title text-3xl font-bold mb-2 text-gray-800">Upload Video</h1>
        <p class="page-description text-gray-600">
          Upload a video file to create highlights with AI-powered editing
        </p>
      </div>

      <!-- Upload Card -->
      <div class="upload-card bg-white rounded-2xl shadow-lg p-8">

        <!-- Drag and Drop Zone -->
        <div id="drop-zone" class="drop-zone">
          <div class="drop-zone-content">
            <svg class="upload-icon w-16 h-16 mx-auto mb-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
            </svg>
            <h3 class="text-xl font-semibold mb-2 text-gray-700">Drop video file here</h3>
            <p class="text-gray-500 mb-4">or</p>
            <button id="browse-button" class="browse-button">
              Browse Files
            </button>
            <input
              type="file"
              id="file-input"
              accept="video/mp4,video/quicktime,video/x-msvideo,.mp4,.mov,.avi"
              class="hidden"
            />
            <p class="text-sm text-gray-400 mt-4">
              Supported formats: MP4, MOV, AVI • Max size: 500MB
            </p>
          </div>
        </div>

        <!-- Upload Progress -->
        <div id="upload-progress" class="upload-progress hidden mt-6">
          <div class="flex items-center justify-between mb-2">
            <span id="file-name" class="text-sm font-medium text-gray-700"></span>
            <span id="progress-percent" class="text-sm font-medium text-indigo-600">0%</span>
          </div>
          <div class="progress-bar-container">
            <div id="progress-bar" class="progress-bar"></div>
          </div>
          <p id="upload-status" class="text-sm text-gray-500 mt-2">Uploading...</p>
        </div>

        <!-- Error Message -->
        <div id="error-message" class="error-message hidden mt-6">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-red-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
            <div>
              <p id="error-text" class="text-sm font-medium text-red-800"></p>
            </div>
          </div>
        </div>

        <!-- Success Message -->
        <div id="success-message" class="success-message hidden mt-6">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <div>
              <p class="text-sm font-medium text-green-800">Upload successful!</p>
              <p class="text-sm text-green-600 mt-1">Redirecting to edit mode...</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Back Link -->
      <div class="mt-6 text-center">
        <a href="/app/dashboard" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">
          ← Back to Dashboard
        </a>
      </div>

    </main>
  </div>
</Layout>

<script>
  // Maximum file size (500MB)
  const MAX_FILE_SIZE = 500 * 1024 * 1024;

  // Allowed video file types
  const ALLOWED_TYPES = ['video/mp4', 'video/quicktime', 'video/x-msvideo'];
  const ALLOWED_EXTENSIONS = ['.mp4', '.mov', '.avi'];

  // DOM elements
  const dropZone = document.getElementById('drop-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const browseButton = document.getElementById('browse-button');
  const uploadProgress = document.getElementById('upload-progress');
  const progressBar = document.getElementById('progress-bar');
  const progressPercent = document.getElementById('progress-percent');
  const fileName = document.getElementById('file-name');
  const uploadStatus = document.getElementById('upload-status');
  const errorMessage = document.getElementById('error-message');
  const errorText = document.getElementById('error-text');
  const successMessage = document.getElementById('success-message');

  /**
   * Show error message
   */
  function showError(message: string) {
    if (errorMessage && errorText) {
      errorText.textContent = message;
      errorMessage.classList.remove('hidden');
      successMessage?.classList.add('hidden');
      uploadProgress?.classList.add('hidden');
    }
  }

  /**
   * Hide error message
   */
  function hideError() {
    errorMessage?.classList.add('hidden');
  }

  /**
   * Validate file
   */
  function validateFile(file: File): string | null {
    // Check file type
    const hasValidType = ALLOWED_TYPES.includes(file.type);
    const hasValidExtension = ALLOWED_EXTENSIONS.some(ext => file.name.toLowerCase().endsWith(ext));

    if (!hasValidType && !hasValidExtension) {
      return 'Invalid file type. Please upload MP4, MOV, or AVI files only.';
    }

    // Check file size
    if (file.size > MAX_FILE_SIZE) {
      const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
      return `File size (${sizeMB}MB) exceeds the maximum allowed size of 500MB.`;
    }

    return null;
  }

  /**
   * Upload file to server
   */
  async function uploadFile(file: File) {
    hideError();

    // Show progress UI
    uploadProgress?.classList.remove('hidden');
    successMessage?.classList.add('hidden');

    if (fileName) fileName.textContent = file.name;
    if (progressPercent) progressPercent.textContent = '0%';
    if (progressBar) progressBar.style.width = '0%';
    if (uploadStatus) uploadStatus.textContent = 'Uploading...';

    try {
      // Create FormData
      const formData = new FormData();
      formData.append('file', file);

      // Upload with progress tracking
      const xhr = new XMLHttpRequest();

      // Track upload progress
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) {
          const percent = Math.round((e.loaded / e.total) * 100);
          if (progressBar) progressBar.style.width = `${percent}%`;
          if (progressPercent) progressPercent.textContent = `${percent}%`;
        }
      });

      // Handle completion
      xhr.addEventListener('load', () => {
        if (xhr.status === 200 || xhr.status === 201) {
          const response = JSON.parse(xhr.responseText);

          if (response.success && response.videoId) {
            // Show success message
            uploadProgress?.classList.add('hidden');
            successMessage?.classList.remove('hidden');

            // Redirect to edit page after 1.5 seconds
            setTimeout(() => {
              window.location.href = `/app/edit?videoId=${response.videoId}`;
            }, 1500);
          } else {
            showError(response.error || 'Upload failed. Please try again.');
            uploadProgress?.classList.add('hidden');
          }
        } else {
          const response = JSON.parse(xhr.responseText);
          showError(response.error || `Upload failed with status ${xhr.status}`);
          uploadProgress?.classList.add('hidden');
        }
      });

      // Handle errors
      xhr.addEventListener('error', () => {
        showError('Network error occurred during upload. Please try again.');
        uploadProgress?.classList.add('hidden');
      });

      // Send request
      xhr.open('POST', '/api/video/upload');
      xhr.send(formData);

    } catch (error) {
      console.error('[Upload] Error:', error);
      showError('An unexpected error occurred. Please try again.');
      uploadProgress?.classList.add('hidden');
    }
  }

  /**
   * Handle file selection
   */
  function handleFileSelect(file: File) {
    // Validate file
    const validationError = validateFile(file);
    if (validationError) {
      showError(validationError);
      return;
    }

    // Upload file
    uploadFile(file);
  }

  // ======================================================================
  // Event Listeners
  // ======================================================================

  // Browse button click
  browseButton?.addEventListener('click', () => {
    fileInput?.click();
  });

  // File input change
  fileInput?.addEventListener('change', (e) => {
    const files = (e.target as HTMLInputElement).files;
    if (files && files.length > 0) {
      handleFileSelect(files[0]);
    }
  });

  // Drag and drop events
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });

  dropZone?.addEventListener('dragleave', () => {
    dropZone.classList.remove('drag-over');
  });

  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');

    const files = e.dataTransfer?.files;
    if (files && files.length > 0) {
      handleFileSelect(files[0]);
    }
  });
</script>

<style>
  /* Upload Page Layout */
  .upload-page {
    min-height: calc(100vh - 120px);
  }

  /* Page Header */
  .page-header {
    text-align: center;
  }

  .page-title {
    color: #1f2937;
  }

  .page-description {
    color: #6b7280;
    font-size: 16px;
  }

  /* Upload Card */
  .upload-card {
    border: 1px solid #e5e7eb;
  }

  /* Drop Zone */
  .drop-zone {
    border: 2px dashed #cbd5e0;
    border-radius: 12px;
    padding: 60px 40px;
    text-align: center;
    background-color: #f9fafb;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .drop-zone:hover {
    border-color: #667eea;
    background-color: #f3f4f6;
  }

  .drop-zone.drag-over {
    border-color: #667eea;
    background-color: #eef2ff;
    border-width: 3px;
  }

  .drop-zone-content {
    pointer-events: none;
  }

  .upload-icon {
    pointer-events: none;
  }

  /* Browse Button */
  .browse-button {
    display: inline-block;
    padding: 12px 32px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    pointer-events: auto;
  }

  .browse-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
  }

  .browse-button:active {
    transform: translateY(0);
  }

  /* Progress Bar */
  .progress-bar-container {
    width: 100%;
    height: 8px;
    background-color: #e5e7eb;
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  /* Error Message */
  .error-message {
    padding: 16px;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
  }

  /* Success Message */
  .success-message {
    padding: 16px;
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
  }

  /* Hidden utility */
  .hidden {
    display: none !important;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .drop-zone {
      padding: 40px 20px;
    }

    .page-title {
      font-size: 24px;
    }

    .upload-card {
      padding: 24px;
    }
  }
</style>
