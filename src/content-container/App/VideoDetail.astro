---
/**
 * Video Detail Content Component
 *
 * Displays completed video with player, metadata, and actions.
 */

import Layout from '../../layouts/Layout.astro';
import VideoPlayer from '../../components/video/VideoPlayer';

interface Props {
  data: any;
  userRole: string;
  userId: string;
}

const { data, userRole, userId } = Astro.props;
const project = data.project;
---

<Layout title={`Video: ${project.name || 'Untitled'}`}>
  <div class="video-detail-page">
    <div class="container max-w-6xl mx-auto px-6 py-8">
      <!-- Back Button -->
      <div class="mb-6">
        <a href="/app/dashboard" class="back-link">
          ← Back to Dashboard
        </a>
      </div>

      <!-- Page Header -->
      <div class="mb-8">
        <h1 class="text-heading-lg mb-2">{project.name || 'Untitled Video'}</h1>
        {project.description && (
          <p class="text-body-md text-neutral-600">{project.description}</p>
        )}
      </div>

      <!-- Video Player -->
      <div class="video-player-container mb-8">
        <VideoPlayer
          videoUrl={project.outputVideoUrl}
          thumbnailUrl={project.thumbnailUrl}
          title={project.name || 'Untitled'}
          client:load
        />
      </div>

      <!-- Metadata & Actions -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Metadata Card -->
        <div class="metadata-card">
          <h2 class="card-title">Video Details</h2>
          <div class="metadata-grid">
            <div class="metadata-item">
              <div class="metadata-label">Quality</div>
              <div class="metadata-value">{project.renderQuality || 'Standard'}</div>
            </div>
            <div class="metadata-item">
              <div class="metadata-label">Duration</div>
              <div class="metadata-value">
                {project.estimatedDuration
                  ? `${Math.floor(project.estimatedDuration / 60)}:${(project.estimatedDuration % 60).toString().padStart(2, '0')}`
                  : 'N/A'
                }
              </div>
            </div>
            <div class="metadata-item">
              <div class="metadata-label">Status</div>
              <div class="metadata-value">
                <span class="status-badge status-completed">Completed</span>
              </div>
            </div>
            <div class="metadata-item">
              <div class="metadata-label">Created</div>
              <div class="metadata-value">
                {new Date(project.createdAt).toLocaleDateString()}
              </div>
            </div>
            <div class="metadata-item">
              <div class="metadata-label">Scenes</div>
              <div class="metadata-value">{project.totalScenes || 0}</div>
            </div>
            <div class="metadata-item">
              <div class="metadata-label">Minutes Used</div>
              <div class="metadata-value">{project.usedMinutes || 0} min</div>
            </div>
          </div>
        </div>

        <!-- Actions Card -->
        <div class="actions-card">
          <h2 class="card-title">Actions</h2>
          <div class="actions-grid">
            <a
              href={project.outputVideoUrl}
              download
              class="action-button action-primary"
            >
              📥 Download Video
            </a>
            <button
              class="action-button action-secondary"
              id="share-button"
            >
              🔗 Share Link
            </button>
            <a
              href={`/app/videos/${project.id}/edit`}
              class="action-button action-secondary"
            >
              ✏️ Edit Video
            </a>
            {userRole === 'SuperAdmin' || userRole === 'StudioAdmin' ? (
              <button
                class="action-button action-danger"
                id="delete-button"
                data-project-id={project.id}
              >
                🗑️ Delete Video
              </button>
            ) : null}
          </div>
        </div>
      </div>

      <!-- Script Preview (if available) -->
      {project.script && (
        <div class="script-card">
          <h2 class="card-title">Original Script</h2>
          <div class="script-content">
            {project.script}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<script>
  // Share button functionality
  document.getElementById('share-button')?.addEventListener('click', async () => {
    const url = window.location.href;

    if (navigator.share) {
      try {
        await navigator.share({
          title: 'Check out my AI-generated video',
          url: url,
        });
      } catch (err) {
        console.log('Share canceled');
      }
    } else {
      // Fallback: copy to clipboard
      await navigator.clipboard.writeText(url);
      alert('Link copied to clipboard!');
    }
  });

  // Delete button functionality
  document.getElementById('delete-button')?.addEventListener('click', async (e) => {
    const button = e.target as HTMLButtonElement;
    const projectId = button.getAttribute('data-project-id');

    if (!confirm('Are you sure you want to delete this video? This action cannot be undone.')) {
      return;
    }

    try {
      button.disabled = true;
      button.textContent = 'Deleting...';

      const response = await fetch(`/api/video/${projectId}`, {
        method: 'DELETE',
      });

      if (response.ok) {
        alert('Video deleted successfully');
        window.location.href = '/app/dashboard';
      } else {
        const data = await response.json();
        alert(`Failed to delete video: ${data.error || 'Unknown error'}`);
        button.disabled = false;
        button.textContent = '🗑️ Delete Video';
      }
    } catch (error) {
      console.error('Delete error:', error);
      alert('Failed to delete video. Please try again.');
      button.disabled = false;
      button.textContent = '🗑️ Delete Video';
    }
  });
</script>

<style>
  .video-detail-page {
    min-height: 100vh;
    background-color: var(--color-surface-50);
  }

  .back-link {
    color: var(--color-primary-300);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .video-player-container {
    background-color: var(--color-neutral-900);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }

  .metadata-card,
  .actions-card,
  .script-card {
    background-color: white;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-neutral-800);
    margin: 0 0 1rem 0;
  }

  .metadata-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .metadata-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metadata-label {
    font-size: var(--text-xs);
    color: var(--color-neutral-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metadata-value {
    font-size: var(--text-sm);
    color: var(--color-neutral-800);
    font-weight: 500;
  }

  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .status-completed {
    background-color: var(--color-success-100);
    color: var(--color-success-700);
  }

  .actions-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .action-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .action-primary {
    background-color: var(--color-primary-300);
    color: var(--color-neutral-900);
  }

  .action-primary:hover {
    background-color: var(--color-primary-400);
  }

  .action-secondary {
    background-color: var(--color-surface-200);
    color: var(--color-neutral-700);
  }

  .action-secondary:hover {
    background-color: var(--color-surface-300);
  }

  .action-danger {
    background-color: var(--color-error-100);
    color: var(--color-error-700);
  }

  .action-danger:hover {
    background-color: var(--color-error-200);
  }

  .script-content {
    background-color: var(--color-surface-100);
    padding: 1rem;
    border-radius: var(--radius-md);
    font-family: 'Courier New', monospace;
    font-size: var(--text-sm);
    line-height: 1.6;
    white-space: pre-wrap;
    color: var(--color-neutral-700);
  }

  @media (max-width: 768px) {
    .metadata-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
