---
/**
 * Billing & Subscription Management Content Component
 *
 * Features:
 * - Current subscription plan display with status
 * - Usage meter showing minutes used/remaining
 * - Billing period information
 * - Plan upgrade/downgrade options
 * - Payment history table
 * - Stripe portal access for payment methods
 * - Subscription cancellation
 *
 * @component App/Billing
 */

import Layout from '../../layouts/Layout.astro';
import UsageMeter from '../../components/video/UsageMeter';

interface Props {
  data: any;
  userRole: string;
  userId: string;
}

const { data, userRole, userId } = Astro.props;

// Extract subscription data
const subscription = data.subscription || {
  subscriptionStatus: 'none',
  planType: 'free',
  usedMinutesThisPeriod: 0,
  totalMinutesLimit: 5,
  periodStart: new Date().toISOString(),
  periodEnd: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(),
};

const paymentHistory = data.paymentHistory || [];

// Plan information
const planInfo = {
  free: {
    name: 'Free Tier',
    price: '$0',
    minutesLimit: 5,
    features: ['5 minutes/month', 'Basic AI voices', 'Standard quality', 'Email support'],
  },
  creator: {
    name: 'Creator',
    price: '$29',
    minutesLimit: 60,
    features: ['60 minutes/month', 'Premium AI voices', 'HD quality', 'Priority support', 'Custom characters'],
  },
  pro: {
    name: 'Pro',
    price: '$99',
    minutesLimit: 300,
    features: ['300 minutes/month', 'All premium features', '4K quality', 'Priority support', 'Advanced analytics', 'Team collaboration'],
  },
  enterprise: {
    name: 'Enterprise',
    price: 'Custom',
    minutesLimit: 'Unlimited',
    features: ['Unlimited minutes', 'Dedicated account manager', 'Custom integrations', 'SLA guarantee', 'White-label options'],
  },
};

const currentPlan = planInfo[subscription.planType] || planInfo.free;
const hasActiveSubscription = subscription.subscriptionStatus === 'active' || subscription.subscriptionStatus === 'trialing';

// Calculate days remaining in billing period
const periodEnd = subscription.periodEnd ? new Date(subscription.periodEnd) : new Date();
const daysRemaining = Math.ceil((periodEnd.getTime() - Date.now()) / (1000 * 60 * 60 * 24));

// Format dates for display
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// Status badge styling
const getStatusBadge = (status: string) => {
  const badges = {
    active: { text: 'Active', class: 'bg-success-100 text-success-700' },
    trialing: { text: 'Trial', class: 'bg-primary-100 text-primary-700' },
    past_due: { text: 'Past Due', class: 'bg-danger-100 text-danger-700' },
    canceled: { text: 'Canceled', class: 'bg-neutral-100 text-neutral-700' },
    none: { text: 'Free Plan', class: 'bg-neutral-100 text-neutral-600' },
  };
  return badges[status] || badges.none;
};

const statusBadge = getStatusBadge(subscription.subscriptionStatus);
---

<Layout title="Billing & Subscription">
  <div class="billing-page">
    <div class="container">
      {/* Page Header */}
      <div class="page-header">
        <div class="header-content">
          <h1 class="page-title">Billing & Subscription</h1>
          <p class="page-description">
            Manage your subscription plan, usage, and payment methods
          </p>
        </div>
      </div>

      <div class="billing-grid">
        {/* Left Column: Current Plan & Usage */}
        <div class="main-content">
          {/* Current Plan Card */}
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Current Plan</h2>
              <span class={`status-badge ${statusBadge.class}`}>
                {statusBadge.text}
              </span>
            </div>
            <div class="card-body">
              <div class="plan-details">
                <div class="plan-name-price">
                  <h3 class="plan-name">{currentPlan.name}</h3>
                  <div class="plan-price">
                    <span class="price-amount">{currentPlan.price}</span>
                    {subscription.planType !== 'free' && subscription.planType !== 'enterprise' && (
                      <span class="price-period">/month</span>
                    )}
                  </div>
                </div>

                <div class="plan-features">
                  <h4 class="features-title">Plan Features</h4>
                  <ul class="features-list">
                    {currentPlan.features.map((feature) => (
                      <li class="feature-item">
                        <span class="feature-icon">✓</span>
                        <span class="feature-text">{feature}</span>
                      </li>
                    ))}
                  </ul>
                </div>

                {/* Billing Period Info */}
                {hasActiveSubscription && subscription.periodStart && subscription.periodEnd && (
                  <div class="billing-period">
                    <div class="period-row">
                      <span class="period-label">Billing Period</span>
                      <span class="period-value">
                        {formatDate(subscription.periodStart)} - {formatDate(subscription.periodEnd)}
                      </span>
                    </div>
                    <div class="period-row">
                      <span class="period-label">Days Remaining</span>
                      <span class="period-value">
                        {daysRemaining} {daysRemaining === 1 ? 'day' : 'days'}
                      </span>
                    </div>
                  </div>
                )}

                {/* Plan Actions */}
                <div class="plan-actions">
                  {subscription.planType === 'free' ? (
                    <a href="/app/pricing" class="btn btn-primary">
                      Upgrade Plan
                    </a>
                  ) : (
                    <>
                      {subscription.planType !== 'enterprise' && (
                        <a href="/app/pricing" class="btn btn-secondary">
                          Change Plan
                        </a>
                      )}
                      {hasActiveSubscription && (
                        <button
                          id="manage-billing-btn"
                          class="btn btn-secondary"
                          data-user-id={userId}
                        >
                          Manage Billing
                        </button>
                      )}
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* Usage Meter */}
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Usage This Period</h2>
            </div>
            <div class="card-body">
              <UsageMeter
                client:load
                usedMinutes={subscription.usedMinutesThisPeriod}
                totalMinutes={subscription.totalMinutesLimit}
                planType={subscription.planType}
                periodStart={subscription.periodStart}
                periodEnd={subscription.periodEnd}
                onUpgrade={() => window.location.href = '/app/pricing'}
              />

              <div class="usage-details">
                <div class="usage-stat">
                  <span class="stat-label">Used</span>
                  <span class="stat-value">{subscription.usedMinutesThisPeriod} min</span>
                </div>
                <div class="usage-stat">
                  <span class="stat-label">Remaining</span>
                  <span class="stat-value">
                    {Math.max(0, subscription.totalMinutesLimit - subscription.usedMinutesThisPeriod)} min
                  </span>
                </div>
                <div class="usage-stat">
                  <span class="stat-label">Limit</span>
                  <span class="stat-value">
                    {subscription.planType === 'enterprise' ? '∞' : subscription.totalMinutesLimit} min
                  </span>
                </div>
              </div>
            </div>
          </div>

          {/* Payment History */}
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Payment History</h2>
            </div>
            <div class="card-body">
              {paymentHistory.length > 0 ? (
                <div class="payment-table-wrapper">
                  <table class="payment-table">
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Invoice</th>
                      </tr>
                    </thead>
                    <tbody>
                      {paymentHistory.map((payment) => (
                        <tr>
                          <td>{formatDate(payment.date)}</td>
                          <td>{payment.description}</td>
                          <td class="amount">${(payment.amount / 100).toFixed(2)}</td>
                          <td>
                            <span class={`payment-status ${payment.status === 'paid' ? 'paid' : 'failed'}`}>
                              {payment.status === 'paid' ? 'Paid' : 'Failed'}
                            </span>
                          </td>
                          <td>
                            {payment.invoiceUrl ? (
                              <a href={payment.invoiceUrl} target="_blank" rel="noopener noreferrer" class="invoice-link">
                                View
                              </a>
                            ) : (
                              <span class="text-neutral-300">-</span>
                            )}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div class="empty-state">
                  <div class="empty-icon">📄</div>
                  <p class="empty-text">No payment history yet</p>
                  {subscription.planType === 'free' && (
                    <p class="empty-hint">Upgrade to a paid plan to see your payment history</p>
                  )}
                </div>
              )}
            </div>
          </div>

          {/* Cancel Subscription */}
          {hasActiveSubscription && subscription.planType !== 'free' && (
            <div class="card danger-card">
              <div class="card-header">
                <h2 class="card-title">Danger Zone</h2>
              </div>
              <div class="card-body">
                <div class="danger-content">
                  <div class="danger-info">
                    <h3 class="danger-title">Cancel Subscription</h3>
                    <p class="danger-description">
                      Your subscription will remain active until the end of your billing period ({formatDate(subscription.periodEnd || '')}).
                      After that, you'll be downgraded to the free plan.
                    </p>
                  </div>
                  <button
                    id="cancel-subscription-btn"
                    class="btn btn-danger"
                    data-user-id={userId}
                  >
                    Cancel Subscription
                  </button>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Right Column: Quick Actions & Info */}
        <div class="sidebar">
          {/* Quick Actions */}
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Quick Actions</h2>
            </div>
            <div class="card-body">
              <div class="quick-actions">
                <a href="/app/pricing" class="action-link">
                  <span class="action-icon">🎯</span>
                  <div class="action-content">
                    <span class="action-label">View All Plans</span>
                    <span class="action-hint">Compare features and pricing</span>
                  </div>
                </a>

                {hasActiveSubscription && (
                  <button
                    id="update-payment-method-btn"
                    class="action-link action-button"
                    data-user-id={userId}
                  >
                    <span class="action-icon">💳</span>
                    <div class="action-content">
                      <span class="action-label">Update Payment Method</span>
                      <span class="action-hint">Manage your payment methods</span>
                    </div>
                  </button>
                )}

                <a href="/app/dashboard" class="action-link">
                  <span class="action-icon">📊</span>
                  <div class="action-content">
                    <span class="action-label">View Dashboard</span>
                    <span class="action-hint">See your video projects</span>
                  </div>
                </a>
              </div>
            </div>
          </div>

          {/* Billing Support */}
          <div class="card">
            <div class="card-header">
              <h2 class="card-title">Need Help?</h2>
            </div>
            <div class="card-body">
              <div class="support-content">
                <p class="support-text">
                  Have questions about billing or need to discuss custom enterprise plans?
                </p>
                <a href="mailto:billing@videostudio.ai" class="btn btn-secondary btn-block">
                  Contact Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- Client-side JavaScript for Stripe integration -->
<script>
  // Manage Billing Portal
  document.getElementById('manage-billing-btn')?.addEventListener('click', async (e) => {
    const btn = e.target as HTMLButtonElement;
    const userId = btn.dataset.userId;

    btn.disabled = true;
    btn.textContent = 'Loading...';

    try {
      const response = await fetch('/api/billing/portal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId }),
      });

      const data = await response.json();

      if (data.success && data.url) {
        window.location.href = data.url;
      } else {
        alert('Failed to open billing portal: ' + (data.error || 'Unknown error'));
        btn.disabled = false;
        btn.textContent = 'Manage Billing';
      }
    } catch (error) {
      console.error('Error opening billing portal:', error);
      alert('Failed to open billing portal. Please try again.');
      btn.disabled = false;
      btn.textContent = 'Manage Billing';
    }
  });

  // Update Payment Method (opens Stripe portal)
  document.getElementById('update-payment-method-btn')?.addEventListener('click', async (e) => {
    const btn = e.target as HTMLButtonElement;
    const userId = btn.dataset.userId;

    btn.disabled = true;
    const originalText = btn.querySelector('.action-label')?.textContent || 'Update Payment Method';
    const labelEl = btn.querySelector('.action-label');
    if (labelEl) labelEl.textContent = 'Loading...';

    try {
      const response = await fetch('/api/billing/portal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId }),
      });

      const data = await response.json();

      if (data.success && data.url) {
        window.location.href = data.url;
      } else {
        alert('Failed to open billing portal: ' + (data.error || 'Unknown error'));
        btn.disabled = false;
        if (labelEl) labelEl.textContent = originalText;
      }
    } catch (error) {
      console.error('Error opening billing portal:', error);
      alert('Failed to open billing portal. Please try again.');
      btn.disabled = false;
      if (labelEl) labelEl.textContent = originalText;
    }
  });

  // Cancel Subscription
  document.getElementById('cancel-subscription-btn')?.addEventListener('click', async (e) => {
    const btn = e.target as HTMLButtonElement;
    const userId = btn.dataset.userId;

    const confirmed = confirm(
      'Are you sure you want to cancel your subscription?\n\n' +
      'Your subscription will remain active until the end of your billing period, ' +
      'then you\'ll be downgraded to the free plan.'
    );

    if (!confirmed) return;

    btn.disabled = true;
    btn.textContent = 'Canceling...';

    try {
      const response = await fetch('/api/billing/subscription', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId }),
      });

      const data = await response.json();

      if (data.success) {
        alert('Subscription canceled. Your plan will remain active until the end of your billing period.');
        window.location.reload();
      } else {
        alert('Failed to cancel subscription: ' + (data.error || 'Unknown error'));
        btn.disabled = false;
        btn.textContent = 'Cancel Subscription';
      }
    } catch (error) {
      console.error('Error canceling subscription:', error);
      alert('Failed to cancel subscription. Please try again.');
      btn.disabled = false;
      btn.textContent = 'Cancel Subscription';
    }
  });
</script>

<style>
  .billing-page {
    padding: 24px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Page Header */
  .page-header {
    margin-bottom: 8px;
  }

  .header-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .page-title {
    font-size: 32px;
    font-weight: 700;
    color: #2d3748;
    margin: 0;
  }

  .page-description {
    font-size: 16px;
    color: #718096;
    margin: 0;
  }

  /* Grid Layout */
  .billing-grid {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 24px;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Card Styles */
  .card {
    background-color: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #e2e8f0;
  }

  .card-title {
    font-size: 18px;
    font-weight: 700;
    color: #2d3748;
    margin: 0;
  }

  .card-body {
    padding: 24px;
  }

  /* Status Badge */
  .status-badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }

  /* Plan Details */
  .plan-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .plan-name-price {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .plan-name {
    font-size: 24px;
    font-weight: 700;
    color: #2d3748;
    margin: 0;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .price-amount {
    font-size: 32px;
    font-weight: 700;
    color: #2d3748;
  }

  .price-period {
    font-size: 16px;
    color: #718096;
  }

  /* Plan Features */
  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .features-title {
    font-size: 14px;
    font-weight: 600;
    color: #718096;
    text-transform: uppercase;
    margin: 0;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: #2d3748;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background-color: #DFFF00;
    border-radius: 50%;
    font-size: 12px;
    font-weight: 700;
    color: #2d3748;
  }

  /* Billing Period */
  .billing-period {
    padding: 16px;
    background-color: #f7fafc;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .period-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .period-label {
    font-size: 14px;
    color: #718096;
  }

  .period-value {
    font-size: 14px;
    font-weight: 600;
    color: #2d3748;
  }

  /* Plan Actions */
  .plan-actions {
    display: flex;
    gap: 12px;
  }

  /* Usage Details */
  .usage-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid #e2e8f0;
  }

  .usage-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 600;
    color: #718096;
    text-transform: uppercase;
  }

  .stat-value {
    font-size: 20px;
    font-weight: 700;
    color: #2d3748;
  }

  /* Payment Table */
  .payment-table-wrapper {
    overflow-x: auto;
  }

  .payment-table {
    width: 100%;
    border-collapse: collapse;
  }

  .payment-table th {
    text-align: left;
    padding: 12px 16px;
    background-color: #f7fafc;
    border-bottom: 2px solid #e2e8f0;
    font-size: 13px;
    font-weight: 600;
    color: #718096;
    text-transform: uppercase;
  }

  .payment-table td {
    padding: 16px;
    border-bottom: 1px solid #e2e8f0;
    font-size: 14px;
    color: #2d3748;
  }

  .payment-table td.amount {
    font-weight: 600;
  }

  .payment-status {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
  }

  .payment-status.paid {
    background-color: #c6f6d5;
    color: #22543d;
  }

  .payment-status.failed {
    background-color: #fed7d7;
    color: #742a2a;
  }

  .invoice-link {
    color: #4299e1;
    text-decoration: none;
    font-weight: 600;
  }

  .invoice-link:hover {
    text-decoration: underline;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 40px 20px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-text {
    font-size: 16px;
    font-weight: 600;
    color: #2d3748;
    margin: 0 0 8px 0;
  }

  .empty-hint {
    font-size: 14px;
    color: #718096;
    margin: 0;
  }

  /* Danger Card */
  .danger-card {
    border-color: #fc8181;
  }

  .danger-card .card-header {
    background-color: #fff5f5;
    border-bottom-color: #fc8181;
  }

  .danger-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .danger-info {
    flex: 1;
  }

  .danger-title {
    font-size: 16px;
    font-weight: 700;
    color: #742a2a;
    margin: 0 0 8px 0;
  }

  .danger-description {
    font-size: 14px;
    color: #718096;
    margin: 0;
  }

  /* Quick Actions */
  .quick-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .action-link {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background-color: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .action-link:hover {
    background-color: #edf2f7;
    border-color: #cbd5e0;
  }

  .action-link.action-button {
    cursor: pointer;
    width: 100%;
    text-align: left;
  }

  .action-icon {
    font-size: 24px;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: white;
    border-radius: 8px;
  }

  .action-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .action-label {
    font-size: 14px;
    font-weight: 600;
    color: #2d3748;
  }

  .action-hint {
    font-size: 12px;
    color: #718096;
  }

  /* Support Content */
  .support-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .support-text {
    font-size: 14px;
    color: #718096;
    margin: 0;
  }

  /* Button Styles */
  .btn {
    padding: 12px 24px;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary {
    background: linear-gradient(135deg, #DFFF00 0%, #c4e600 100%);
    color: #2d3748;
  }

  .btn-primary:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(223, 255, 0, 0.4);
  }

  .btn-secondary {
    background-color: #edf2f7;
    color: #2d3748;
