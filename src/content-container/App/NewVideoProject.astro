---
/**
 * New Video Project Content Component
 *
 * Form for creating a new Video AI project:
 * - Project name and description
 * - Script editor
 * - Quality selector
 * - Character selection
 * - Usage meter display
 *
 * @component App/NewVideoProject
 */

import Layout from '../../layouts/Layout.astro';
import ScriptEditor from '../../components/video/ScriptEditor';
import QualitySelector from '../../components/video/QualitySelector';
import UsageMeter from '../../components/video/UsageMeter';

interface Props {
  data: any;
  userRole: string;
  userId: string;
}

const { data, userRole, userId } = Astro.props;

// User subscription data
const subscription = data?.subscription || {
  planType: 'free',
  usedMinutes: 0,
  totalMinutes: 5,
  periodEnd: null,
};

// Available characters
const characters = data?.characters || [];

// Initial form state (passed to client script)
const initialState = JSON.stringify({
  projectName: '',
  projectDescription: '',
  script: '',
  qualityTier: 'high',
  selectedCharacters: [],
});
---

<Layout title="Create New Video Project">
  <div class="new-video-project">
    <div class="container">
      {/* Header */}
      <div class="page-header">
        <h1 class="page-title">Create New Video</h1>
        <p class="page-description">
          Write a script and AI will generate your video with scenes, animations, and audio.
        </p>
      </div>

      {/* Two Column Layout */}
      <div class="content-grid">
        {/* Left Column - Form */}
        <div class="form-column">
          <form id="video-project-form" class="video-form">
            {/* Project Info */}
            <div class="form-section">
              <label for="project-name" class="form-label">Project Name *</label>
              <input
                type="text"
                id="project-name"
                name="projectName"
                required
                placeholder="e.g., Product Demo Video"
                class="text-input"
              />
            </div>

            <div class="form-section">
              <label for="project-description" class="form-label">Description (Optional)</label>
              <textarea
                id="project-description"
                name="projectDescription"
                placeholder="What is this video about?"
                rows="2"
                class="textarea-input"
              ></textarea>
            </div>

            {/* Script Editor */}
            <div class="form-section">
              <ScriptEditor
                client:idle
                value=""
                onChange={(value) => window.updateScript(value)}
                onSceneParse={(scenes) => window.handleSceneParse(scenes)}
                showSceneBreakdown={true}
              />
            </div>

            {/* Quality Selector */}
            <div class="form-section">
              <QualitySelector
                client:idle
                value="high"
                onChange={(value) => window.updateQuality(value)}
                planType={subscription.planType}
              />
            </div>

            {/* Usage Display */}
            <div class="form-section">
              <UsageMeter
                client:idle
                usedMinutes={subscription.usedMinutes}
                totalMinutes={subscription.totalMinutes}
                planType={subscription.planType}
                periodEnd={subscription.periodEnd}
                onUpgrade={() => window.location.href = '/pricing'}
              />
            </div>

            {/* Submit Button */}
            <div class="form-actions">
              <button
                type="submit"
                id="submit-btn"
                class="submit-btn"
                disabled={subscription.planType === 'free' && subscription.usedMinutes >= subscription.totalMinutes}
              >
                <span class="btn-text">Generate Video</span>
                <span class="btn-spinner hidden">⟳</span>
              </button>
              {subscription.planType === 'free' && subscription.usedMinutes >= subscription.totalMinutes && (
                <p class="limit-message">
                  ⚠️ You've reached your monthly limit. <a href="/pricing">Upgrade to continue</a>
                </p>
              )}
            </div>
          </form>
        </div>

        {/* Right Column - Info & Preview */}
        <div class="info-column">
          {/* How It Works */}
          <div class="info-card">
            <h2 class="card-title">How It Works</h2>
            <ol class="steps-list">
              <li><strong>Write your script</strong> - Describe scenes with dialogue and action</li>
              <li><strong>Choose quality</strong> - Select 720p, 1080p, or 4K resolution</li>
              <li><strong>AI generates</strong> - We create keyframes, animations, and assemble your video</li>
              <li><strong>Download</strong> - Get your video in minutes</li>
            </ol>
          </div>

          {/* Script Tips */}
          <div class="info-card">
            <h2 class="card-title">Script Tips</h2>
            <ul class="tips-list">
              <li>Use <code>[Scene X]</code> markers to separate scenes</li>
              <li>Include character names in ALL CAPS before dialogue</li>
              <li>Add parentheticals for tone: <code>(excited)</code>, <code>(whispering)</code></li>
              <li>Describe settings: <code>INT. LOCATION - TIME</code></li>
            </ul>
          </div>

          {/* Example Script */}
          <div class="info-card">
            <h2 class="card-title">Example Script</h2>
            <pre class="example-script">[Scene 1] - INT. COFFEE SHOP - MORNING

ALEX
(entering, excited to camera)
Hey everyone, welcome back to the channel!

[Scene 2] - EXT. PARK - AFTERNOON

Alex walks through the park, gesturing at the scenery.

ALEX (V.O.)
Today we're exploring something amazing...</pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<!-- Client Script for Form Handling -->
<script define:vars={{ initialState, userId, userRole }}>
  // State
  let formState = {
    projectName: '',
    projectDescription: '',
    script: '',
    qualityTier: 'high',
    selectedCharacters: [],
    parsedScenes: [],
  };

  // Update functions for React components
  window.updateScript = (value) => {
    formState.script = value;
  };

  window.updateQuality = (value) => {
    formState.qualityTier = value;
  };

  // Handle scene parsing callback
  window.handleSceneParse = (scenes) => {
    formState.parsedScenes = scenes;

    // Log scene information for debugging
    console.log('Parsed scenes:', scenes);

    // Calculate total duration
    const totalDuration = scenes.reduce((acc, scene) => acc + scene.estimatedDuration, 0);
    console.log('Estimated duration:', `${Math.floor(totalDuration / 60)}m ${Math.floor(totalDuration % 60)}s`);

    // Extract characters
    const characters = Array.from(
      new Set(scenes.flatMap((scene) => scene.characters))
    );
    console.log('Characters found:', characters);
  };

  // Form submission
  const form = document.getElementById('video-project-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = submitBtn.querySelector('.btn-text');
  const btnSpinner = submitBtn.querySelector('.btn-spinner');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate
    if (!formState.script.trim()) {
      alert('Please enter a script for your video');
      return;
    }

    if (formState.parsedScenes.length === 0) {
      alert('Please add at least one scene to your script. Use the format: [Scene 1] - INT. LOCATION - TIME');
      return;
    }

    // Get form values
    const formData = new FormData(form);
    formState.projectName = formData.get('projectName');
    formState.projectDescription = formData.get('projectDescription');

    // Show loading state
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnSpinner.classList.remove('hidden');

    try {
      const response = await fetch('/api/video/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...formState,
          userId,
          // Include parsed scene data for video generation
          scenes: formState.parsedScenes.map((scene) => ({
            number: scene.number,
            heading: scene.heading,
            location: scene.location,
            time: scene.time,
            type: scene.type,
            content: scene.content,
            estimatedDuration: scene.estimatedDuration,
            characters: scene.characters,
          })),
        }),
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'Failed to create project');
      }

      // Redirect to project detail/progress page
      window.location.href = `/app/projects/${result.projectId}`;
    } catch (error) {
      console.error('Error creating project:', error);
      alert(error.message || 'Failed to create project. Please try again.');
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnSpinner.classList.add('hidden');
    }
  });
</script>

<style>
  .new-video-project {
    padding: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Page Header */
  .page-header {
    text-align: center;
  }

  .page-title {
    font-size: 32px;
    font-weight: 700;
    color: #2d3748;
    margin: 0 0 8px 0;
  }

  .page-description {
    font-size: 16px;
    color: #718096;
    margin: 0;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 32px;
    align-items: start;
  }

  /* Form Column */
  .form-column {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .video-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 14px;
    font-weight: 600;
    color: #2d3748;
  }

  .text-input,
  .textarea-input {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .text-input:focus,
  .textarea-input:focus {
    outline: none;
    border-color: #DFFF00;
    box-shadow: 0 0 0 3px rgba(223, 255, 0, 0.2);
  }

  .textarea-input {
    resize: vertical;
    min-height: 60px;
    font-family: inherit;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 24px;
    background: linear-gradient(135deg, #DFFF00 0%, #c4e600 100%);
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    color: #2d3748;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .submit-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(223, 255, 0, 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none !important;
  }

  .limit-message {
    font-size: 13px;
    color: #c53030;
    text-align: center;
    margin: 0;
  }

  .limit-message a {
    color: #c53030;
    text-decoration: underline;
  }

  /* Info Column */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 24px;
  }

  .info-card {
    padding: 20px;
    background-color: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
  }

  .card-title {
    font-size: 16px;
    font-weight: 700;
    color: #2d3748;
    margin: 0 0 12px 0;
  }

  .steps-list {
    padding-left: 20px;
    margin: 0;
  }

  .steps-list li {
    margin-bottom: 8px;
    color: #4a5568;
    line-height: 1.5;
  }

  .tips-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tips-list li {
    padding: 6px 0;
    color: #4a5568;
    font-size: 13px;
    border-bottom: 1px solid #f7fafc;
  }

  .tips-list li:last-child {
    border-bottom: none;
  }

  .tips-list code {
    padding: 2px 4px;
    background-color: #f7fafc;
    border-radius: 3px;
    font-family: 'Monaco', monospace;
    font-size: 12px;
    color: #6b46c1;
  }

  .example-script {
    padding: 12px;
    background-color: #1a202c;
    color: #e2e8f0;
    border-radius: 8px;
    font-family: 'Monaco', monospace;
    font-size: 12px;
    line-height: 1.6;
    overflow-x: auto;
    margin: 0;
  }

  /* Mobile Responsive */
  @media (max-width: 968px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .info-column {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .new-video-project {
      padding: 16px;
    }

    .page-title {
      font-size: 24px;
    }

    .page-description {
      font-size: 14px;
    }
  }
</style>
