---
/**
 * Better Auth Login Page
 * Email/Password authentication
 */

import LoginForm from '../../../components/widgets/LoginForm.tsx';
import { getSession } from '../../../lib/auth/session-adapter';
import { isBetterAuth } from '../../../lib/auth/feature-flag';

// Redirect to Xano login if not using Better Auth
if (!isBetterAuth()) {
    return Astro.redirect('/log-in/');
}

// If already logged in, redirect to dashboard
const session = await getSession(Astro.request, Astro.cookies);
if (session) {
    return Astro.redirect('/app/dashboard/');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Data3D</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #7cd1f9 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            padding: 40px;
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo-section {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo {
            font-size: 32px;
            font-weight: 700;
            color: #7cd1f9;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 10px;
        }

        .welcome-text {
            text-align: center;
            margin-bottom: 30px;
        }

        .welcome-text h2 {
            color: #2d3748;
            font-size: 24px;
            margin-bottom: 10px;
        }

        .welcome-text p {
            color: #718096;
            font-size: 14px;
        }

        .signup-link {
            text-align: center;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .signup-link p {
            color: #718096;
            font-size: 14px;
        }

        .signup-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

        .signup-link a:hover {
            color: #5a67d8;
        }

        @media (max-width: 480px) {
            .login-card {
                padding: 30px 20px;
            }

            .logo {
                font-size: 28px;
            }

            .welcome-text h2 {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="logo-section">
                <a href="/" class="logo">Data3D</a>
            </div>

            <div class="welcome-text">
                <h2>Welcome Back</h2>
                <p>Sign in with your email and password</p>
            </div>

            <LoginForm client:load />

            <div class="signup-link">
                <p>Don't have an account? <a href="/auth/register/">Sign up</a></p>
            </div>
        </div>
    </div>
</body>
</html>
