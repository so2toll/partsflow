---
/**
 * Registration Page
 *
 * Organization-aware registration that creates:
 * - User account via Better Auth
 * - Organization in graph
 * - User node in graph
 * - First project
 *
 * POST /register
 */

import OrganizationRegisterForm from "../../../components/widgets/OrganizationRegisterForm";

const metadata = {
  title: "Create Your Account - Video AI Studio",
  description: "Get started with Video AI Content Studio",
};

---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{metadata.title}</title>
  <meta name="description" content={metadata.description} />
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #0F1923 0%, #1A202C 50%, #0B1117 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
  </style>
</head>
<body>
  <div
    style={{
      width: "100%",
      maxWidth: "480px",
      backgroundColor: "white",
      borderRadius: "20px",
      padding: "40px",
      boxShadow: "0 20px 60px rgba(0, 0, 0, 0.3)",
    }}
  >
    {/* Header */}
    <div style={{ textAlign: "center", marginBottom: "30px" }}>
      <h1
        style={{
          fontSize: "28px",
          fontWeight: "700",
          marginBottom: "10px",
          background: "linear-gradient(135deg, #ff5c00 0%, #ff6b00 100%)",
          WebkitBackgroundClip: "text",
          WebkitTextFillColor: "transparent",
          backgroundClip: "text",
        }}
      >
        Create Your Account
      </h1>
      <p style={{ fontSize: "16px", color: "#718096", margin: 0 }}>
        Start creating amazing video content with AI
      </p>
    </div>

    {/* Registration Form */}
    <OrganizationRegisterForm redirectUrl="/app/dashboard" client:load />

    {/* Login Link */}
    <div style={{ textAlign: "center", marginTop: "24px" }}>
      <p style={{ fontSize: "14px", color: "#718096", margin: 0 }}>
        Already have an account?{" "}
        <a
          href="/auth/login/"
          style={{
            color: "#ff5c00",
            textDecoration: "none",
            fontWeight: "600",
          }}
        >
          Sign in
        </a>
      </p>
    </div>

    {/* Terms */}
    <div style={{ textAlign: "center", marginTop: "24px" }}>
      <p
        style={{
          fontSize: "12px",
          color: "#a0aec0",
          margin: 0,
          lineHeight: "1.5",
        }}
      >
        By creating an account, you agree to our Terms of Service and Privacy
        Policy
      </p>
    </div>
  </div>
</body>
</html>
