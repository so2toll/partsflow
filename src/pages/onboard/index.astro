---
/**
 * Onboarding Entry Page
 *
 * Entry point for new users with invite tokens.
 * Validates token and shows role selection cards.
 *
 * Route: /onboard?token=xxx
 */

import Layout from '../../layouts/Layout.astro';
import { inviteRepository } from '../../lib/db/repositories/InviteRepository';

// Get token from URL
const token = Astro.url.searchParams.get('token');

// Validate token
let invite = null;
let error = null;

if (!token) {
  error = 'missing_token';
} else {
  try {
    invite = await inviteRepository.validateToken(token);
    if (!invite) {
      error = 'invalid_token';
    }
  } catch (e) {
    console.error('[Onboard] Error validating token:', e);
    error = 'server_error';
  }
}
---

<Layout title="Join MotoFlow">
  <div class="onboard-page">
    <!-- Header -->
    <header class="onboard-header">
      <a href="/" class="brand-logo">MOTOFLOW</a>
    </header>

    <main class="onboard-main">
      {error ? (
        <div class="error-container">
          <div class="error-card">
            <span class="material-symbols-outlined error-icon">error</span>
            <h1 class="error-title">
              {error === 'missing_token' && 'Missing Invite Link'}
              {error === 'invalid_token' && 'Invalid or Expired Invite'}
              {error === 'server_error' && 'Something Went Wrong'}
            </h1>
            <p class="error-description">
              {error === 'missing_token' && 'Please use the invite link provided by your administrator to join MotoFlow.'}
              {error === 'invalid_token' && 'This invite link is no longer valid. It may have expired or already been used. Please contact your administrator for a new invite.'}
              {error === 'server_error' && 'We encountered an error validating your invite. Please try again or contact support.'}
            </p>
            <a href="/" class="btn btn-secondary">
              <span class="material-symbols-outlined">arrow_back</span>
              Return Home
            </a>
          </div>
        </div>
      ) : (
        <div class="welcome-container">
          <div class="welcome-header">
            <span class="welcome-badge">JOIN MOTOFLOW</span>
            <h1 class="welcome-title">Welcome to MotoFlow</h1>
            <p class="welcome-description">
              Select your role to get started with your account setup.
            </p>
          </div>

          {/* Show the invite type if it's already specified */}
          {invite?.type && (
            <div class="invite-type-notice">
              <span class="material-symbols-outlined">info</span>
              <span>
                Your invite is for {invite.type === 'shop_owner' ? 'Shop Owner' : 'Driver'} registration.
              </span>
            </div>
          )}

          <div class="role-cards">
            <!-- Shop Owner Card -->
            <a
              href={`/onboard/shop?token=${token}`}
              class={`role-card ${invite?.type === 'driver' ? 'disabled' : ''}`}
              data-type="shop_owner"
            >
              <div class="role-icon shop-icon">
                <span class="material-symbols-outlined">storefront</span>
              </div>
              <h2 class="role-title">Shop Owner</h2>
              <p class="role-description">
                I own or manage an auto repair shop and need parts delivered quickly.
              </p>
              <ul class="role-features">
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  Search 200+ local suppliers
                </li>
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  30-60 minute delivery
                </li>
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  Track orders in real-time
                </li>
              </ul>
              <div class="role-cta">
                Get Started
                <span class="material-symbols-outlined">arrow_forward</span>
              </div>
            </a>

            <!-- Driver Card -->
            <a
              href={`/onboard/driver?token=${token}`}
              class={`role-card ${invite?.type === 'shop_owner' ? 'disabled' : ''}`}
              data-type="driver"
            >
              <div class="role-icon driver-icon">
                <span class="material-symbols-outlined">local_shipping</span>
              </div>
              <h2 class="role-title">Driver</h2>
              <p class="role-description">
                I want to deliver auto parts and earn money on my own schedule.
              </p>
              <ul class="role-features">
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  Flexible hours
                </li>
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  Competitive pay + tips
                </li>
                <li>
                  <span class="material-symbols-outlined">check_circle</span>
                  Weekly payouts
                </li>
              </ul>
              <div class="role-cta">
                Get Started
                <span class="material-symbols-outlined">arrow_forward</span>
              </div>
            </a>
          </div>

          <p class="help-text">
            Questions? Contact <a href="mailto:support@motoflow.io">support@motoflow.io</a>
          </p>
        </div>
      )}
    </main>

    <!-- Footer -->
    <footer class="onboard-footer">
      <p>&copy; 2025 MotoFlow. All rights reserved.</p>
    </footer>
  </div>
</Layout>

<style>
  .onboard-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: #f9fafb;
  }

  /* Header */
  .onboard-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 64px;
    background-color: #0B1117;
    display: flex;
    align-items: center;
    padding: 0 24px;
    z-index: 1000;
  }

  .brand-logo {
    font-size: 24px;
    font-weight: 700;
    color: #ff5c00;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  /* Main */
  .onboard-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px 24px 24px;
    margin-top: 64px;
  }

  /* Error State */
  .error-container {
    max-width: 480px;
    width: 100%;
  }

  .error-card {
    background-color: white;
    padding: 48px;
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
  }

  .error-icon {
    font-size: 64px;
    color: #ef4444;
    margin-bottom: 24px;
  }

  .error-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 12px;
  }

  .error-description {
    font-size: 16px;
    color: #6b7280;
    line-height: 1.6;
    margin: 0 0 32px;
  }

  /* Welcome State */
  .welcome-container {
    max-width: 800px;
    width: 100%;
  }

  .welcome-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .welcome-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ff5c00;
    margin-bottom: 16px;
    display: block;
  }

  .welcome-title {
    font-size: 36px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 12px;
  }

  .welcome-description {
    font-size: 18px;
    color: #6b7280;
    margin: 0;
  }

  /* Invite Type Notice */
  .invite-type-notice {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background-color: rgba(255, 92, 0, 0.1);
    border-radius: 8px;
    margin-bottom: 32px;
    font-size: 14px;
    color: #ff5c00;
  }

  .invite-type-notice .material-symbols-outlined {
    font-size: 20px;
  }

  /* Role Cards */
  .role-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }

  @media (min-width: 640px) {
    .role-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .role-card {
    background-color: white;
    padding: 32px;
    border-radius: 16px;
    text-decoration: none;
    border: 2px solid #e5e7eb;
    transition: all 300ms;
    display: flex;
    flex-direction: column;
  }

  .role-card:hover {
    border-color: #ff5c00;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(255, 92, 0, 0.15);
  }

  .role-card.disabled {
    opacity: 0.4;
    pointer-events: none;
    cursor: not-allowed;
  }

  .role-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .role-icon .material-symbols-outlined {
    font-size: 32px;
    color: white;
  }

  .shop-icon {
    background: linear-gradient(135deg, #ff5c00, #e05000);
  }

  .driver-icon {
    background: linear-gradient(135deg, #3b82f6, #2563eb);
  }

  .role-title {
    font-size: 24px;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 8px;
  }

  .role-description {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.6;
    margin: 0 0 24px;
  }

  .role-features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .role-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: #4b5563;
  }

  .role-features .material-symbols-outlined {
    font-size: 18px;
    color: #22c55e;
  }

  .role-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    background-color: #f3f4f6;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: #1a202c;
    margin-top: auto;
    transition: all 200ms;
  }

  .role-card:hover .role-cta {
    background-color: #ff5c00;
    color: white;
  }

  .role-cta .material-symbols-outlined {
    font-size: 18px;
    transition: transform 200ms;
  }

  .role-card:hover .role-cta .material-symbols-outlined {
    transform: translateX(4px);
  }

  /* Help Text */
  .help-text {
    text-align: center;
    font-size: 14px;
    color: #6b7280;
  }

  .help-text a {
    color: #ff5c00;
    text-decoration: none;
  }

  .help-text a:hover {
    text-decoration: underline;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 200ms;
    border: none;
  }

  .btn-secondary {
    background-color: #f3f4f6;
    color: #1a202c;
  }

  .btn-secondary:hover {
    background-color: #e5e7eb;
  }

  .btn .material-symbols-outlined {
    font-size: 18px;
  }

  /* Footer */
  .onboard-footer {
    padding: 24px;
    text-align: center;
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
  }

  .onboard-footer p {
    font-size: 12px;
    color: #9ca3af;
    margin: 0;
  }
</style>
