---
/**
 * Video Generation Progress Page
 *
 * Shows real-time progress of video generation job.
 * Standard RBAC pattern with ProgressTracker component.
 * Polls job status and updates UI automatically.
 */

import { getSession } from "@/lib/auth/session-adapter";
import { getLoginUrl } from "@/lib/auth/feature-flag";
import { RBAC_CONFIG } from "@/lib/configs/rbacConfig.js";
import RBACComponent from "@/components/RBAC/RBACComponent.astro";
import { getPageData } from "@/lib/data/appPageData";

// ========================================================================
// PAGE CONFIGURATION
// ========================================================================
const currentPage = 'appVideoProgress';

// ========================================================================
// STANDARD PAGE LOGIC
// ========================================================================

// Get session
const session = await getSession(Astro.request, Astro.cookies);

if (!session) {
  return Astro.redirect(getLoginUrl());
}

// Get user info
const user = session.user;
const userId = user?.id;
const userRole = user?.role;
const organizationId = user?.organizationId;

// ========================================================================
// GET PROJECT ID FROM URL
// ========================================================================
const { id: projectId } = Astro.params;

if (!projectId) {
  return Astro.redirect('/app/dashboard?error=missing_project_id');
}

// ========================================================================
// DATA FETCHING
// ========================================================================

const data = await getPageData(currentPage, userId, userRole, organizationId);

// Add project ID to data for the component
data.projectId = projectId;

// ========================================================================
// ROLE VALIDATION
// ========================================================================

if (!userRole) {
  console.log('[VideoProgress] No role found for user:', userId);
  return Astro.redirect('/access-denied?reason=no_role&page=' + currentPage);
}

if (!RBAC_CONFIG[userRole]) {
  console.log('[VideoProgress] Invalid role:', userRole);
  return Astro.redirect('/access-denied?reason=invalid_role&page=' + currentPage);
}

if (!RBAC_CONFIG[userRole][currentPage]) {
  console.log('[VideoProgress] Role', userRole, 'does not have access to page:', currentPage);
  return Astro.redirect('/access-denied?reason=no_access&page=' + currentPage);
}

// ========================================================================
// RENDER RBAC COMPONENT
// ========================================================================
---
<RBACComponent
  userRole={userRole}
  userId={userId}
  data={data}
  currentPage={currentPage}
/>
