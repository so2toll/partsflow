---
/**
 * App Pricing Page
 *
 * Standard page template following the RBAC pattern.
 */

import { getSession } from "../../lib/auth/session-adapter";
import { getLoginUrl } from "../../lib/auth/feature-flag";
import { RBAC_CONFIG } from "../../lib/configs/rbacConfig.js";
import RBACComponent from "../../components/RBAC/RBACComponent.astro";
import { userSubscriptionRepository } from "../../lib/db/repositories";

// ============================================================================
// PAGE CONFIGURATION
// ============================================================================
const currentPage = 'appPricing';

// ============================================================================
// STANDARD PAGE LOGIC
// ============================================================================

// Get session
const session = await getSession(Astro.request, Astro.cookies);

// Pricing is publicly accessible, but we show personalized data if logged in
let userId: string | null = null;
let userRole: string | null = null;
let subscription = null;

if (session) {
  userId = session?.user?.global_id || session?.user?.id;
  userRole = session?.user?.role;

  // Get user's subscription if logged in
  if (userId) {
    subscription = await userSubscriptionRepository.getSubscription(userId);
  }
}

const data = {
  subscription,
};

// ============================================================================
// RENDER
// ============================================================================

// If logged in with valid role, use RBAC component
// Otherwise render pricing page directly
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Video AI Content Studio - Simple, transparent pricing for all plans" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Pricing - Video AI Content Studio</title>
  </head>
  <body>
    <div id="pricing-root">
      {
        session && userRole && RBAC_CONFIG[userRole] ? (
          <RBACComponent
            userRole={userRole}
            userId={userId || ''}
            data={data}
            currentPage="appDashboard"
          />
        ) : (
          // Public pricing page - redirect to login for action
          <div class="public-pricing">
            <div class="pricing-header">
              <a href="/" class="logo">Video AI Studio</a>
              <a href="/login" class="login-btn">Sign In</a>
            </div>
            <!-- Pricing content will be loaded here -->
            <div class="pricing-cta">
              <a href="/login" class="cta-button">Get Started Free</a>
            </div>
          </div>
        )
      }
    </div>
  </body>
</html>

<style>
  .public-pricing {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .pricing-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid #e2e8f0;
  }

  .logo {
    font-size: 20px;
    font-weight: 700;
    color: #2d3748;
    text-decoration: none;
  }

  .login-btn {
    padding: 8px 16px;
    background-color: #edf2f7;
    color: #4a5568;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.2s;
  }

  .login-btn:hover {
    background-color: #e2e8f0;
  }

  .pricing-cta {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
  }

  .cta-button {
    padding: 14px 32px;
    background: linear-gradient(135deg, #DFFF00 0%, #c4e600 100%);
    color: #2d3748;
    border-radius: 8px;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .cta-button:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(223, 255, 0, 0.4);
  }
</style>
