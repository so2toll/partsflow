---
/**
 * MotoFlow Landing Page Test
 * Parts delivery and logistics platform
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="MotoFlow | Urgent Professional Parts Delivery">
  <div class="motoflow-landing">

    <!-- Top Navigation -->
    <header class="top-nav">
      <div class="nav-content">
        <div class="nav-left">
          <span class="brand-logo">MOTOFLOW</span>
        </div>
        <div class="nav-center">
          <nav class="nav-links">
            <a href="#" class="nav-link">HOME</a>
            <a href="#" class="nav-link">DRIVERS</a>
            <a href="#" class="nav-link">EARN</a>
            <a href="#" class="nav-link">ACCOUNT</a>
          </nav>
        </div>
        <div class="nav-right">
          <button class="btn btn-primary btn-sm">GET PARTS NOW</button>
        </div>
      </div>
    </header>

    <main class="main-content">
      <!-- Hero Section (Dark) -->
      <section class="hero-section">
        <div class="hero-bg">
          <div class="hero-gradient"></div>
        </div>
        <div class="hero-container">
          <span class="hero-badge">BALTIMORE · WASHINGTON DC · NOW LAUNCHING</span>
          <h1 class="hero-title">
            Parts. <span class="text-gradient">Delivered.</span> Fast.
          </h1>
          <p class="hero-description">
            The real-time parts sourcing network for repair shops and city fleets.
            <strong class="hero-highlight">AI-powered search. 30–60 min SLA. Guaranteed.</strong>
          </p>
          <div class="hero-cta">
            <button class="btn btn-primary btn-xl glow-orange">Get Parts Now</button>
            <button class="btn btn-secondary btn-xl">View Network</button>
          </div>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <div class="stat-value">30-60</div>
            <div class="stat-label">Min SLA</div>
          </div>
          <div class="hero-stat">
            <div class="stat-value">200+</div>
            <div class="stat-label">Suppliers</div>
          </div>
          <div class="hero-stat">
            <div class="stat-value">15M+</div>
            <div class="stat-label">Parts in Network</div>
          </div>
          <div class="hero-stat">
            <div class="stat-value">$0</div>
            <div class="stat-label">Signup Fee</div>
          </div>
        </div>
      </section>

      <!-- KPI Ticker -->
      <div class="kpi-ticker">
        <div class="ticker-content">
          <span class="ticker-item">30–60 Min Delivery</span>
          <span class="ticker-item">AI Part Search</span>
          <span class="ticker-item">200+ Baltimore Suppliers</span>
          <span class="ticker-item">Municipal Fleet Ready</span>
          <span class="ticker-item">Guaranteed ETA or Refund</span>
          <span class="ticker-item">Sourcewell Cooperative</span>
          <span class="ticker-item">30–60 Min Delivery</span>
          <span class="ticker-item">AI Part Search</span>
          <span class="ticker-item">200+ Baltimore Suppliers</span>
          <span class="ticker-item">Municipal Fleet Ready</span>
          <span class="ticker-item">Guaranteed ETA or Refund</span>
          <span class="ticker-item">Sourcewell Cooperative</span>
        </div>
      </div>

      <!-- Problem/Solution Section -->
      <section class="problem-solution">
        <div class="section-container">
          <div class="section-header">
            <span class="badge-text">THE COST OF WAITING</span>
            <h2>Every minute on the lift is money bleeding out.</h2>
          </div>
          <div class="comparison-grid">
            <!-- Problem Card -->
            <div class="card problem-card">
              <span class="material-symbols-outlined error-icon">timer_off</span>
              <h3>Fragmented Sourcing</h3>
              <p>Calling 4-6 suppliers for every ticket wastes 45+ minutes of bay time. Inconsistent ETAs and "no-stock" surprises kill your daily throughput.</p>
              <div class="card-footer">
                <span class="error-text">IDLE BAY LOSS: $150/HR</span>
              </div>
            </div>
            <!-- Solution Card -->
            <div class="card solution-card">
              <span class="material-symbols-outlined success-icon">bolt</span>
              <h3>The MotoFlow Advantage</h3>
              <p>Our AI scans 200+ local inventories in 15 seconds. Unified dispatch brings parts directly to your shop while your tech stays on the job.</p>
              <div class="card-footer">
                <span class="success-text">TIME SAVED: 62 HRS/MO</span>
              </div>
            </div>
          </div>
          <div class="comparison-grid">
            <!-- Spacer for padding -->
          </div>
          </div>
        </div>
      </section>

      <!-- How It Works -->
      <section class="how-it-works">
        <div class="section-container">
          <div class="section-header">
            <h2>Search. Order. Delivered.</h2>
          </div>
          <div class="steps-grid">
            <div class="step-card">
              <div class="step-number">01</div>
              <h4>AI-Powered Search</h4>
              <p>Type anything — "2019 Civic front brakes" or a part number. AI extracts the right part and finds every local supplier instantly.</p>
            </div>
            <div class="step-card">
              <div class="step-number">02</div>
              <h4>Speed or Price</h4>
              <p>Sort by fastest ETA or lowest cost. Set priority level P1–P3. One click to order.</p>
            </div>
            <div class="step-card">
              <div class="step-number">03</div>
              <h4>Driver Dispatched</h4>
              <p>Algorithm assigns the nearest driver with surge incentives. Live GPS from pickup to drop-off.</p>
            </div>
            <div class="step-card">
              <div class="step-number">04</div>
              <h4>Parts on Your Lift</h4>
              <p>30–60 minutes, guaranteed. One-tap reorder for saved vehicles and common repairs.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Dual Mode Feature -->
      <section class="dual-mode">
        <div class="mode-card light-mode">
          <div class="mode-content">
            <span class="badge-text">LOCAL REPAIR SHOP</span>
            <h3>Maximize Bay Velocity</h3>
            <p>Search 200+ Baltimore suppliers simultaneously. AI-powered queries. Parts on your lift in 30–60 min.</p>
          </div>
        </div>
        <div class="mode-card dark-mode">
          <div class="mode-content">
            <span class="mode-badge tertiary">MUNICIPAL FLEET</span>
            <h3>Operational Governance</h3>
            <p>Priority dispatch for city fleets. Department tracking, P1/P2/P3 queues. Sourcewell-ready procurement.</p>
          </div>
        </div>
      </section>

      <!-- Pricing -->
      <section class="pricing-section">
        <div class="section-container">
          <div class="section-header">
            <span class="badge-text">TRANSPARENT PRICING</span>
            <h2>Built for shops. Scaled for cities.</h2>
          </div>
          <div class="pricing-grid">
            <!-- Free Tier -->
            <div class="card pricing-card">
              <div class="pricing-tier">PAY-AS-YOU-GO</div>
              <div class="pricing-price">$0<span>/mo</span></div>
              <p>Plus $18-22 delivery fee</p>
              <ul class="pricing-features">
                <li><span class="material-symbols-outlined">check_circle</span> Unlimited AI Search</li>
                <li><span class="material-symbols-outlined">check_circle</span> Live GPS Tracking</li>
                <li><span class="material-symbols-outlined">check_circle</span> SMS Notifications</li>
              </ul>
              <button class="btn btn-secondary btn-lg btn-block">Get Started</button>
            </div>
            <!-- Pro Tier -->
            <div class="card pricing-card pricing-popular">
              <div class="popular-badge">MOST POPULAR</div>
              <div class="pricing-tier primary-color">SHOP PRO</div>
              <div class="pricing-price">$149<span>/mo</span></div>
              <p>Fixed overhead for elite shops</p>
              <ul class="pricing-features">
                <li><span class="material-symbols-outlined">check_circle</span> Priority Dispatch Queue</li>
                <li><span class="material-symbols-outlined">check_circle</span> Detailed Spend Analytics</li>
                <li><span class="material-symbols-outlined">check_circle</span> Dedicated Account Manager</li>
                <li><span class="material-symbols-outlined">check_circle</span> API Integration Ready</li>
              </ul>
              <button class="btn btn-primary btn-lg btn-block glow-orange">Select Pro</button>
            </div>
            <!-- Government Tier -->
            <div class="card pricing-card pricing-dark">
              <div class="pricing-tier">GOVERNMENT</div>
              <div class="pricing-price">Custom</div>
              <p>Sourcewell-eligible pricing</p>
              <ul class="pricing-features">
                <li><span class="material-symbols-outlined">check_circle</span> P1 Emergency Queue</li>
                <li><span class="material-symbols-outlined">check_circle</span> Dept-Level Governance</li>
                <li><span class="material-symbols-outlined">check_circle</span> SLA Breach Protection</li>
              </ul>
              <button class="btn btn-outline btn-lg btn-block">Contact Sales</button>
            </div>
          </div>
        </div>
      </section>

      <!-- Social Proof -->
      <section class="social-proof">
        <div class="testimonials-grid">
          <div class="card testimonial-card">
            <p>"I spend 45 minutes a day calling parts stores. If MotoFlow cuts that in half, I'd pay for it twice over."</p>
            <div class="testimonial-author">
              <div class="author-avatar primary-bg">MT</div>
              <div>
                <div class="author-name">Marcus T.</div>
                <div class="author-title">Owner, Eastside Auto</div>
              </div>
            </div>
          </div>
          <div class="card testimonial-card">
            <p>"Our garage has 12 bays and 4 city departments. Coordinating parts is a nightmare. This is exactly what we've needed."</p>
            <div class="testimonial-author">
              <div class="author-avatar tertiary-bg">DW</div>
              <div>
                <div class="author-name">Capt. D. Williams</div>
                <div class="author-title">Baltimore City Fleet Manager</div>
              </div>
            </div>
          </div>
          <div class="card testimonial-card">
            <p>"Fastest I got a part was 22 minutes. I need that to be the standard, not the exception. MotoFlow makes it happen."</p>
            <div class="testimonial-author">
              <div class="author-avatar primary-bg">CR</div>
              <div>
                <div class="author-name">Carlos R.</div>
                <div class="author-title">Master Tech, Precision Imports</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Final CTA -->
      <section class="final-cta">
        <div class="cta-container">
          <span class="badge badge-cta">BALTIMORE LAUNCH · EARLY ACCESS</span>
          <h2>First 50 shops get priority access.</h2>
          <p>Free onboarding. No commitment. Be the fastest shop in your zip code.</p>
          <form class="cta-form">
            <input type="email" placeholder="Your email address" class="input" />
            <button type="submit" class="btn btn-primary btn-lg glow-orange">Request Early Access</button>
          </form>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="landing-footer">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="footer-logo">MOTOFLOW</span>
          <p>Unified parts sourcing and delivery for automotive professionals. We bridge the gap between suppliers and technicians with algorithmic precision.</p>
          <div class="footer-social">
            <span class="material-symbols-outlined">public</span>
            <span class="material-symbols-outlined">verified</span>
            <span class="material-symbols-outlined">shield</span>
          </div>
        </div>
        <div class="footer-network">
          <h5>NETWORK</h5>
          <ul>
            <li><a href="#">Supplier Directory</a></li>
            <li><a href="#">Driver Program</a></li>
            <li><a href="#">API Documentation</a></li>
            <li><a href="#">SLA Transparency</a></li>
          </ul>
        </div>
        <div class="footer-support">
          <h5>SUPPORT</h5>
          <ul>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Contact Ops</a></li>
            <li><a href="#">Terms of Service</a></li>
            <li><a href="#">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2025 MOTOFLOW OPS. ALL RIGHTS RESERVED.</p>
        <div>
          <span>STATION 04-B</span>
          <span>SYSTEM STATUS: OPTIMAL</span>
        </div>
      </div>
    </footer>

  </div>
</Layout>

<style>
  .motoflow-landing {
    min-height: 100vh;
  }

  /* Top Nav */
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 64px;
    background-color: #0B1117;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1000;
  }

  .nav-content {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .brand-logo {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-primary-400);
    letter-spacing: -0.02em;
  }

  .nav-center {
    display: none;
  }

  @media (min-width: 768px) {
    .nav-center {
      display: flex;
      flex: 1;
      justify-content: center;
    }
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 200ms;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Main Content */
  .main-content {
    padding-top: 64px;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    background-color: #0B1117;
    min-height: 921px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 48px 24px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    opacity: 0.2;
    background-image: radial-gradient(circle at 20% 30%, var(--color-primary-500) 0%, transparent 40%);
  }

  .hero-container {
    position: relative;
    z-index: 10;
    max-width: 1440px;
    width: 100%;
    text-align: center;
  }

  .hero-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-primary-500);
    margin-bottom: 24px;
    display: block;
  }

  .hero-title {
    font-size: 96px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 24px;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 64px;
    }
  }

  .hero-highlight {
    color: #ffffff;
    font-weight: 600;
  }

  .text-gradient {
    background: linear-gradient(to right, #ffffff, #ffffff, var(--color-primary-500));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 600px;
    margin: 0 auto 48px;
  }

  .hero-cta {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 40px;
  }

  .btn-xl {
    padding: 16px 48px;
    font-size: 16px;
    font-weight: 700;
  }

  .hero-stats {
    margin-top: 80px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 80px;
    width: 100%;
    max-width: 1024px;
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  .hero-stat .stat-value {
    font-size: 36px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-primary-500);
  }

  .hero-stat .stat-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 4px;
  }

  /* KPI Ticker */
  .kpi-ticker {
    background-color: var(--color-primary-500);
    padding: 4px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .ticker-content {
    display: flex;
    animation: ticker 30s linear infinite;
    white-space: nowrap;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0 80px;
  }

  /* Section Styles */
  .problem-solution,
  .how-it-works,
  .pricing-section {
    padding: 80px 24px;
  }

  .section-container {
    max-width: 1440px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 48px;
    max-width: 768px;
  }

  .section-header h2 {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: #0F1923;
  }

  .section-subtext {
    font-size: 16px;
    color: rgba(15, 25, 35, 0.6);
    line-height: 1.7;
    margin-top: 12px;
  }

  /* Comparison Grid */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .comparison-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .problem-card,
  .solution-card {
    padding: 32px;
  }

  .problem-card {
    background-color: #fff1ec;
    border: 1px solid #e4beb1;
  }

  .solution-card {
    background-color: #ffe9e2;
    border: 2px solid var(--color-primary-500);
  }

  .error-icon,
  .success-icon {
    font-size: 48px;
    margin-bottom: 24px;
  }

  .error-icon {
    color: var(--color-danger-500);
  }

  .success-icon {
    color: var(--color-primary-500);
  }

  .problem-card h3,
  .solution-card h3 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .error-text {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-danger-500);
  }

  .success-text {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary-500);
  }

  /* How It Works */
  .how-it-works {
    background-color: #0F1923;
    color: #ffffff;
  }

  .how-it-works .section-header h2 {
    color: #ffffff;
    text-align: center;
    font-size: 48px;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .steps-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .step-card {
    position: relative;
    padding: 24px;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
  }

  .step-number {
    font-size: 64px;
    font-weight: 800;
    color: var(--color-primary-500);
    opacity: 0.5;
    margin-bottom: 12px;
  }

  .step-card h4 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 4px;
    color: #ffffff;
  }

  .step-card p {
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
  }

  /* Dual Mode */
  .dual-mode {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .dual-mode {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mode-card {
    padding: 80px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .light-mode {
    background-color: #fff8f6;
    border-right: 1px solid #e4beb1;
  }

  .dark-mode {
    background-color: #0B1117;
    color: #ffffff;
  }

  .mode-content {
    max-width: 512px;
  }

  .mode-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    border-radius: 4px;
    margin-bottom: 24px;
    display: inline-block;
  }

  .dark-mode .mode-badge.tertiary {
    background-color: #1E90FF;
    color: #ffffff;
  }

  .mode-card h3 {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .light-mode h3 {
    color: #0F1923;
  }

  .dark-mode h3 {
    color: #ffffff;
  }

  .mode-card p {
    font-size: 18px;
    line-height: 1.6;
  }

  .light-mode p {
    color: rgba(15, 25, 35, 0.6);
  }

  .dark-mode p {
    color: rgba(255, 255, 255, 0.6);
  }

  /* Pricing */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 960px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pricing-card {
    padding: 48px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-popular {
    border: 2px solid var(--color-primary-500);
  }

  .popular-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-primary-500);
    color: #ffffff;
    padding: 4px 24px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pricing-tier {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
    color: rgba(15, 25, 35, 0.6);
  }

  .pricing-tier.primary-color {
    color: var(--color-primary-500);
  }

  .pricing-price {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 8px;
  }

