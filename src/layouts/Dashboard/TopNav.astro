---
/**
 * Top Navigation Bar
 *
 * Universal top nav that works across all pages:
 * - Shows page title
 * - Shows user info
 * - App-specific navigation when on app pages
 * - Logout functionality
 */

const { title, userRole, userId, organizationId, organization } = Astro.props;

// Determine if this is an app page
const isAppPage = title && (
  title.includes('Dashboard') && !title.includes('Admin') ||
  title.includes('Teams') ||
  title.includes('Projects')
);
---

<header class="header">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center w-100">
            <div class="d-flex align-items-center">
                <button class="btn sidebar-toggle me-3" id="sidebar-toggle" type="button" aria-label="Toggle Sidebar" aria-expanded="true" aria-controls="sidebar">
                    <i class="ri-menu-line" aria-hidden="true"></i>
                </button>
                <div>
                    <h1 class="header-title mb-0">{title}</h1>
                    {isAppPage && organization && (
                        <p class="header-subtitle">
                            {organization.name}
                        </p>
                    )}
                    {isAppPage && !organization && userRole === 'SuperAdmin' && (
                        <p class="header-subtitle">
                            SuperAdmin View - All Organizations
                        </p>
                    )}
                </div>
            </div>
            <div class="d-flex align-items-center">
                <!-- App-specific navigation -->
                {isAppPage && (
                    <>
                        <a href="/app/dashboard" class="me-2 nav-link">
                            Dashboard
                        </a>
                        <a href="/app/projects" class="me-2 nav-link">
                            Projects
                        </a>
                        <a href="/app/teams" class="me-3 nav-link">
                            Teams
                        </a>
                    </>
                )}

                <!-- User info and logout -->
                <div class="dropdown user-dropdown">
                    <button
                        class="d-flex align-items-center text-decoration-none dropdown-toggle border-0 bg-transparent"
                        id="userDropdown"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        aria-label="User menu"
                    >
                        <div class="avatar avatar-sm avatar-with-badge me-2">
                            <img src="/assets/img/user-4.png" alt="User profile" class="avatar-image">
                            <span class="avatar-status avatar-status-online"></span>
                        </div>
                        <span class="d-none d-md-inline header-username">
                            {organization?.name || userRole || 'User'}
                        </span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                        <li><a class="dropdown-item" href="/settings/profile">
                            <i class="ri-user-line me-2"></i>Profile
                        </a></li>
                        <li><a class="dropdown-item" href="/settings/settings">
                            <i class="ri-settings-line me-2"></i>Settings
                        </a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button
                                class="dropdown-item border-0 bg-transparent text-start w-100"
                                id="logout-button"
                                style="cursor: pointer;"
                            >
                                <i class="ri-logout-box-line me-2"></i>Sign Out
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</header>

<script define:vars={{ userRole }}>
    // Handle logout
    const logoutButton = document.getElementById('logout-button');
    if (logoutButton) {
        logoutButton.addEventListener('click', async function(e) {
            e.preventDefault();

            try {
                // Import logout function
                const { logout } = await import('/src/lib/auth/auth-client.js');
                await logout();

                // Clear storage
                localStorage.clear();
                sessionStorage.clear();

                // Redirect to login
                window.location.href = '/auth/login';
            } catch (error) {
                console.error('Logout error:', error);
                // Fallback redirect
                window.location.href = '/auth/login';
            }
        });
    }
</script>

<style>
    .header-title {
        font-size: 24px;
        font-weight: 700;
        color: #2d3748;
        margin: 0;
        line-height: 1.2;
    }

    .header-subtitle {
        font-size: 14px;
        color: #718096;
        margin: 4px 0 0 0;
    }

    .nav-link {
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s;
        background-color: #edf2f7;
        color: #4a5568;
    }

    .nav-link:hover {
        background-color: #e2e8f0;
    }

    .header-username {
        font-size: 14px;
        font-weight: 500;
        color: #4a5568;
    }
</style>
