---
/**
 * Stitch Design System - MotoFlow Operations Sidebar
 *
 * Dark navy sidebar with:
 * - User profile section at top
 * - Navigation items with icons
 * - Active state with orange border
 * - System status indicator at bottom
 */

interface Props {
  userRole?: string;
  userId?: string;
  currentPage?: string;
}

const { userRole, userId, currentPage } = Astro.props;

const navItems = [
  { id: 'map', label: 'MAP', icon: 'map' },
  { id: 'feed', label: 'FEED', icon: 'format_list_bulleted' },
  { id: 'dispatch', label: 'DISPATCH', icon: 'local_shipping' },
  { id: 'revenue', label: 'REVENUE', icon: 'payments' },
  { id: 'fleet', label: 'FLEET', icon: 'directions_car' },
  { id: 'settings', label: 'SETTINGS', icon: 'settings' },
];
---

<aside class="sidebar">
  <!-- User Profile Section -->
  <div class="user-profile">
    <div class="user-avatar">
      <span>OP</span>
    </div>
    <div class="user-info">
      <div class="user-name">OPS CONTROL</div>
      <div class="user-station">STATION 04-B</div>
    </div>
  </div>

  <!-- Navigation Items -->
  <nav class="nav-section">
    {navItems.map((item) => (
      <a
        href={`/app/${item.id}`}
        class={`nav-item ${currentPage === item.id ? 'active' : ''}`}
      >
        <span class="material-symbols-outlined nav-icon">{item.icon}</span>
        <span class="nav-label">{item.label}</span>
      </a>
    ))}
  </nav>

  <!-- System Status -->
  <div class="system-status">
    <div class="status-dot"></div>
    <span class="status-text">OPTIMAL</span>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 64px;
    left: 0;
    z-index: 900;
    width: 240px;
    height: calc(100vh - 64px);
    background-color: #1A202C;
    display: flex;
    flex-direction: column;
    padding: 24px 16px;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 1024px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 300ms;
    }
  }

  /* User Profile */
  .user-profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    margin-bottom: 32px;
  }

  .user-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff5c00, #e05000);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .user-info {
    display: flex;
    flex-direction: column;
  }

  .user-name {
    font-size: 14px;
    font-weight: 700;
    color: white;
    letter-spacing: 0.02em;
  }

  .user-station {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  /* Navigation */
  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-radius: 8px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.5);
    transition: all 200ms;
    border-left: 3px solid transparent;
  }

  .nav-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
  }

  .nav-item.active {
    background-color: rgba(255, 92, 0, 0.1);
    color: #ff5c00;
    border-left-color: #ff5c00;
  }

  .nav-icon {
    font-size: 20px;
  }

  .nav-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* System Status */
  .system-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
    }
    50% {
      opacity: 0.8;
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
  }

  .status-text {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.4);
  }
</style>
