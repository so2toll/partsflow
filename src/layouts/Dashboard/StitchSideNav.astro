---
/**
 * Stitch Design System - MotoFlow Operations Sidebar
 *
 * Dark navy sidebar with:
 * - User profile section at top
 * - Navigation items with icons
 * - Active state with orange border
 * - System status indicator at bottom
 */

interface Props {
  userRole?: string;
  userId?: string;
  currentPage?: string;
}

const { userRole, userId, currentPage } = Astro.props;

const navItems = [
  { id: 'dashboard', label: 'Dashboard', icon: 'dashboard', href: '/app/dashboard' },
  { id: 'teams', label: 'Teams', icon: 'groups', href: '/app/teams' },
  { id: 'projects', label: 'Projects', icon: 'folder', href: '/app/projects' },
  { id: 'partsSearch', label: 'Parts Search', icon: 'search', href: '/app/parts/search' },
  { id: 'ordersList', label: 'Orders', icon: 'list', href: '/app/orders' },
];
---

<aside class="sidebar">
  <!-- User Profile Section -->
  <div class="user-profile">
    <div class="user-avatar">
      <span>OP</span>
    </div>
    <div class="user-info">
      <div class="user-name">OPS CONTROL</div>
      <div class="user-station">STATION 04-B</div>
    </div>
  </div>

  <!-- Navigation Items -->
  <nav class="nav-section">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`nav-item ${currentPage === item.id ? 'active' : ''}`}
      >
        <span class="material-symbols-outlined nav-icon">{item.icon}</span>
        <span class="nav-label">{item.label}</span>
      </a>
    ))}

    <!-- Logout Button -->
    <button
      id="sidenav-logout-button"
      class="nav-item logout-button"
      type="button"
    >
      <span class="material-symbols-outlined nav-icon">logout</span>
      <span class="nav-label">LOGOUT</span>
    </button>
  </nav>

  <!-- System Status -->
  <div class="system-status">
    <div class="status-dot"></div>
    <span class="status-text">OPTIMAL</span>
  </div>
</aside>

<script>
  // Client-side logout using Better Auth's client-side signOut
  document.getElementById('sidenav-logout-button')?.addEventListener('click', async function(e) {
    e.preventDefault();

    console.log('[StitchSideNav] Client-side logout initiated');

    // Disable button to prevent double-click
    const button = e.target;
    button.disabled = true;
    button.textContent = 'Logging out...';

    try {
      // Import and use Better Auth's client-side signOut
      const { logout } = await import('../../lib/auth/auth-client');
      console.log('[StitchSideNav] Calling Better Auth client-side signOut...');

      await logout();
      console.log('[StitchSideNav] Better Auth signOut completed successfully');

      // Clear local storage
      localStorage.clear();
      sessionStorage.clear();
      console.log('[StitchSideNav] Cleared storage');

      // Redirect to login
      window.location.href = '/auth/login';
    } catch (error) {
      console.error('[StitchSideNav] Error:', error);
      // Fallback: just redirect
      window.location.href = '/auth/login';
    }
  });
</script>

<style>
  .sidebar {
    position: fixed;
    top: 64px;
    left: 0;
    z-index: 900;
    width: 240px;
    height: calc(100vh - 64px);
    background-color: #1A202C;
    display: flex;
    flex-direction: column;
    padding: 24px 16px;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 1024px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 300ms;
    }
  }

  /* User Profile */
  .user-profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    margin-bottom: 32px;
  }

  .user-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: #ff5c00;
    border-radius: 50%;
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
  }

  .user-name {
    font-size: 14px;
    font-weight: 600;
    color: #ffffff;
  }

  .user-station {
    font-size: 12px;
    color: #a0aec0;
  }

  /* Navigation Items */
  .nav-section {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: #a0aec0;
    transition: all 200ms;
    cursor: pointer;
  }

  .nav-item:hover {
    background-color: rgba(255, 92, 0, 0.1);
    color: #ff5c00;
  }

  .nav-item.active {
    background-color: rgba(255, 92, 0, 0.15);
    color: #ff5c00;
    border-left: 3px solid #ff5c00;
  }

  .nav-icon {
    font-size: 20px;
  }

  .nav-label {
    font-size: 14px;
    font-weight: 500;
  }

  .logout-button {
    margin-top: auto;
    border: none;
    background: none;
    color: #a0aec0;
  }

  .logout-button:hover {
    color: #ff5c00;
  }

  /* System Status */
  .system-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background-color: #22c55e;
    border-radius: 50%;
  }

  .status-text {
    font-size: 12px;
    color: #a0aec0;
  }
</style>
