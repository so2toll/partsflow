---
/**
 * MotoFlow Top Navigation Bar - Role-Based
 *
 * Shows different actions based on user role.
 *
 * Shop Roles: "Search Parts" button
 * Driver: Status indicator
 * SuperAdmin: "Dispatch" button
 */

interface Props {
  userRole?: string;
  userId?: string;
  currentPage?: string;
  organization?: any;
}

const { userRole, userId, currentPage, organization } = Astro.props;

// Role-based navigation items (same as StitchSideNav)
const getNavItems = (role: string | undefined) => {
  // Driver role - minimal navigation
  if (role === 'Driver') {
    return [
      { id: 'appDashboardTest', label: 'Dashboard', icon: 'dashboard', href: '/app/dashboard' },
      { id: 'appProfile', label: 'Profile', icon: 'person', href: '/app/profile' },
    ];
  }

  // SuperAdmin role - full admin navigation
  if (role === 'SuperAdmin') {
    return [
      { id: 'appDashboardTest', label: 'Dashboard', icon: 'dashboard', href: '/app/dashboard' },
      { id: 'adminInvites', label: 'Invites', icon: 'mail', href: '/app/admin/invites' },
      { id: 'adminDispatch', label: 'Dispatch', icon: 'local_shipping', href: '/app/admin/dispatch' },
      { id: 'appTeams', label: 'Teams', icon: 'groups', href: '/app/teams' },
      { id: 'appProjects', label: 'Projects', icon: 'folder', href: '/app/projects' },
    ];
  }

  // Shop Owner (User) role - shop operations navigation
  return [
    { id: 'appDashboardTest', label: 'Dashboard', icon: 'dashboard', href: '/app/dashboard' },
    { id: 'partsSearch', label: 'Parts Search', icon: 'search', href: '/app/parts/search' },
    { id: 'ordersList', label: 'Orders', icon: 'list', href: '/app/orders' },
    { id: 'appProfile', label: 'Profile', icon: 'person', href: '/app/profile' },
  ];
};

const navItems = getNavItems(userRole);

// Role-based CTA button
const getCtaButton = (role: string | undefined) => {
  if (role === 'Driver') {
    return null; // Drivers don't need a CTA button in top nav
  }

  if (role === 'SuperAdmin') {
    return {
      label: 'Dispatch',
      href: '/app/admin/dispatch',
      icon: 'local_shipping',
    };
  }

  // Shop roles
  return {
    label: 'Search Parts',
    href: '/app/parts/search',
    icon: 'search',
  };
};

const ctaButton = getCtaButton(userRole);
---

<header class="top-nav">
  <div class="top-nav-container">
    <!-- Left: Brand -->
    <div class="brand-section">
      <a href="/app/dashboard" class="brand-link">
        <span class="material-symbols-outlined brand-icon">sync</span>
        <span class="brand-text">MotoFlow</span>
      </a>
    </div>
    <span class="divider"></span>

    <!-- Center: Quick Stats (for visual interest) -->
    <div class="stats-section">
      <div class="stat-item">
        <span class="stat-label">Active Orders</span>
        <span class="stat-value">--</span>
      </div>
      {userRole === 'SuperAdmin' && (
        <>
          <div class="stat-item">
            <span class="stat-label">Available Drivers</span>
            <span class="stat-value">--</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">SLA Status</span>
            <span class="stat-value stat-success">GOOD</span>
          </div>
        </>
      )}
    </div>

    <!-- Spacer to push actions to the right -->
    <div class="spacer"></div>

    <!-- Right: Actions -->
    <div class="actions-section">
      {ctaButton && (
        <a href={ctaButton.href} class="btn-cta">
          <span class="material-symbols-outlined">{ctaButton.icon}</span>
          <span>{ctaButton.label}</span>
        </a>
      )}

      <!-- Desktop Icons -->
      <div class="icon-actions desktop-only">
        <button class="icon-btn" title="Notifications">
          <span class="material-symbols-outlined">notifications</span>
        </button>
        <div class="user-avatar" title={userRole || 'User'}>
          <span>{userRole?.slice(0, 2).toUpperCase() || 'US'}</span>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="mobile-menu-btn mobile-only"
        type="button"
        aria-label="Toggle menu"
      >
        <span class="material-symbols-outlined menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="mobile-menu">
    <nav class="mobile-nav">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`mobile-nav-item ${currentPage === item.id ? 'active' : ''}`}
        >
          <span class="material-symbols-outlined mobile-nav-icon">{item.icon}</span>
          <span class="mobile-nav-label">{item.label}</span>
        </a>
      ))}
    </nav>

    <div class="mobile-menu-footer">
      <button id="mobile-logout-button" class="mobile-logout-btn" type="button">
        <span class="material-symbols-outlined">logout</span>
        <span>Logout</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLogoutBtn = document.getElementById('mobile-logout-button');
  let isMenuOpen = false;

  mobileMenuBtn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    if (mobileMenu) {
      mobileMenu.classList.toggle('open', isMenuOpen);
    }
    const icon = mobileMenuBtn?.querySelector('.menu-icon');
    if (icon) {
      icon.textContent = isMenuOpen ? 'close' : 'menu';
    }
  });

  // Close menu when clicking outside
  document.addEventListener('click', (e) => {
    if (isMenuOpen && mobileMenu && !mobileMenu.contains(e.target as Node) && !mobileMenuBtn?.contains(e.target as Node)) {
      isMenuOpen = false;
      mobileMenu.classList.remove('open');
      const icon = mobileMenuBtn?.querySelector('.menu-icon');
      if (icon) {
        icon.textContent = 'menu';
      }
    }
  });

  // Mobile logout
  mobileLogoutBtn?.addEventListener('click', async (e) => {
    e.preventDefault();

    const button = e.target as HTMLButtonElement;
    button.disabled = true;
    button.textContent = 'Logging out...';

    try {
      const { logout } = await import('../../lib/auth/auth-client');
      await logout();
      localStorage.clear();
      sessionStorage.clear();
      window.location.href = '/auth/login';
    } catch (error) {
      console.error('[MobileMenu] Logout error:', error);
      window.location.href = '/auth/login';
    }
  });
</script>

<style>
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 64px;
    background-color: #1A202C;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }

  .top-nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 24px;
    max-width: 100%;
  }

  /* Brand Section */
  .brand-section {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .brand-icon {
    font-size: 24px;
    color: #ff5c00;
  }

  .brand-text {
    font-size: 20px;
    font-weight: 700;
    color: #ffffff;
  }

  .divider {
    width: 1px;
    height: 32px;
    background-color: rgba(255, 255, 255, 0.1);
    margin: 0 24px;
    flex-shrink: 0;
  }

  /* Stats Section */
  .stats-section {
    display: flex;
    gap: 32px;
    flex-shrink: 0;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-label {
    font-size: 11px;
    color: #a0aec0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-value {
    font-size: 18px;
    font-weight: 700;
    color: #ffffff;
  }

  .stat-success {
    color: #22c55e;
  }

  /* Spacer to push actions to the right */
  .spacer {
    flex: 1;
    min-width: 32px;
  }

  /* Actions Section */
  .actions-section {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .btn-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background-color: #ff5c00;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 200ms;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-cta:hover {
    background-color: #e05000;
  }

  .icon-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border: none;
    border-radius: 8px;
    color: #a0aec0;
    cursor: pointer;
    transition: all 200ms;
  }

  .icon-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  .user-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: #ff5c00;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
  }

  /* Mobile Menu Button */
  .mobile-menu-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.05);
    border: none;
    border-radius: 8px;
    color: #ffffff;
    cursor: pointer;
    transition: all 200ms;
  }

  .mobile-menu-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .menu-icon {
    font-size: 24px;
  }

  /* Mobile Menu Dropdown */
  .mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    background-color: #1A202C;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: 16px;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: all 300ms ease;
    z-index: 999;
    max-height: calc(100vh - 64px);
    overflow-y: auto;
  }

  .mobile-menu.open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border-radius: 8px;
    text-decoration: none;
    color: #a0aec0;
    transition: all 200ms;
  }

  .mobile-nav-item:hover {
    background-color: rgba(255, 92, 0, 0.1);
    color: #ff5c00;
  }

  .mobile-nav-item.active {
    background-color: rgba(255, 92, 0, 0.15);
    color: #ff5c00;
    border-left: 3px solid #ff5c00;
  }

  .mobile-nav-icon {
    font-size: 20px;
  }

  .mobile-nav-label {
    font-size: 14px;
    font-weight: 500;
  }

  .mobile-menu-footer {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mobile-logout-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 16px;
    background-color: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 8px;
    color: #ef4444;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 200ms;
  }

  .mobile-logout-btn:hover {
    background-color: rgba(239, 68, 68, 0.2);
  }

  .mobile-logout-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .stats-section {
      display: none;
    }

    .desktop-only {
      display: none !important;
    }

    .mobile-only {
      display: flex !important;
    }

    .spacer {
      display: none;
    }
  }

  @media (min-width: 1025px) {
    .mobile-only {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    .top-nav-container {
      padding: 0 16px;
    }

    .btn-cta span:not(.material-symbols-outlined) {
      display: none;
    }

    .btn-cta {
      padding: 10px;
    }
  }
</style>
