---
/**
 * Driver Sidebar Navigation
 *
 * Simplified sidebar for Driver users with:
 * - Driver profile section at top
 * - Navigation items: Dashboard, My Deliveries, Profile
 * - Status toggle (Available/Offline)
 * - Logout button
 */

interface Props {
  userRole?: string;
  userId?: string;
  currentPage?: string;
}

const { userRole, userId, currentPage } = Astro.props;

const navItems = [
  { id: 'driverDashboard', label: 'DASHBOARD', icon: 'dashboard', href: '/app/driver/dashboard' },
  { id: 'driverProfile', label: 'PROFILE', icon: 'person', href: '/app/profile' },
];
---

<aside class="sidebar">
  <!-- Driver Profile Section -->
  <div class="user-profile">
    <div class="user-avatar">
      <span class="material-symbols-outlined">directions_car</span>
    </div>
    <div class="user-info">
      <div class="user-name">DRIVER</div>
      <div class="user-status" id="driver-status">AVAILABLE</div>
    </div>
  </div>

  <!-- Navigation Items -->
  <nav class="nav-section">
    {navItems.map((item) => (
      <a
        href={item.href}
        class={`nav-item ${currentPage === item.id ? 'active' : ''}`}
      >
        <span class="material-symbols-outlined nav-icon">{item.icon}</span>
        <span class="nav-label">{item.label}</span>
      </a>
    ))}

    <!-- Status Toggle -->
    <div class="status-toggle">
      <button
        id="status-toggle-btn"
        class="toggle-btn available"
        type="button"
      >
        <span class="toggle-dot"></span>
        <span class="toggle-label">AVAILABLE</span>
      </button>
    </div>

    <!-- Logout Button -->
    <button
      id="sidenav-logout-button"
      class="nav-item logout-button"
      type="button"
    >
      <span class="material-symbols-outlined nav-icon">logout</span>
      <span class="nav-label">LOGOUT</span>
    </button>
  </nav>

  <!-- Connection Status -->
  <div class="system-status">
    <div class="status-dot"></div>
    <span class="status-text">CONNECTED</span>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: 64px;
    left: 0;
    z-index: 900;
    width: 240px;
    height: calc(100vh - 64px);
    background-color: #1A202C;
    display: flex;
    flex-direction: column;
    padding: 24px 16px;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 1024px) {
    .sidebar {
      transform: translateX(-100%);
      transition: transform 300ms;
    }
  }

  /* User Profile */
  .user-profile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    margin-bottom: 32px;
  }

  .user-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff5c00, #e05000);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.1);
  }

  .user-avatar .material-symbols-outlined {
    font-size: 24px;
  }

  .user-info {
    display: flex;
    flex-direction: column;
  }

  .user-name {
    font-size: 14px;
    font-weight: 700;
    color: white;
    letter-spacing: 0.02em;
  }

  .user-status {
    font-size: 11px;
    font-weight: 600;
    color: #22c55e;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  .user-status.offline {
    color: rgba(255, 255, 255, 0.4);
  }

  /* Navigation */
  .nav-section {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    border-radius: 8px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.5);
    transition: all 200ms;
    border-left: 3px solid transparent;
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }

  .nav-item:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
  }

  .nav-item.active {
    background-color: rgba(255, 92, 0, 0.1);
    color: #ff5c00;
    border-left-color: #ff5c00;
  }

  .nav-icon {
    font-size: 20px;
  }

  .nav-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* Status Toggle */
  .status-toggle {
    padding: 16px;
    margin-top: 16px;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
    cursor: pointer;
    transition: all 200ms;
  }

  .toggle-btn.available {
    border-color: rgba(34, 197, 94, 0.3);
    background-color: rgba(34, 197, 94, 0.1);
  }

  .toggle-btn.offline {
    border-color: rgba(255, 255, 255, 0.1);
    background-color: rgba(255, 255, 255, 0.05);
  }

  .toggle-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: #22c55e;
    transition: all 200ms;
  }

  .toggle-btn.offline .toggle-dot {
    background-color: rgba(255, 255, 255, 0.3);
  }

  .toggle-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #22c55e;
    transition: all 200ms;
  }

  .toggle-btn.offline .toggle-label {
    color: rgba(255, 255, 255, 0.4);
  }

  /* System Status */
  .system-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    margin-top: auto;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
    }
    50% {
      opacity: 0.8;
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
  }

  .status-text {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.4);
  }

  /* Logout Button */
  .logout-button {
    color: rgba(255, 255, 255, 0.5);
    border: none;
    cursor: pointer !important;
    transition: all 200ms;
    border-left: 3px solid transparent;
    margin-top: auto;
  }

  .logout-button:hover {
    background-color: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    border-left-color: #ef4444;
    cursor: pointer !important;
  }

  .logout-button:active {
    transform: scale(0.98);
  }
</style>

<script>
  // Status toggle
  const toggleBtn = document.getElementById('status-toggle-btn');
  const driverStatus = document.getElementById('driver-status');

  toggleBtn?.addEventListener('click', function() {
    const isAvailable = toggleBtn.classList.contains('available');

    if (isAvailable) {
      toggleBtn.classList.remove('available');
      toggleBtn.classList.add('offline');
      toggleBtn.querySelector('.toggle-label').textContent = 'OFFLINE';
      if (driverStatus) {
        driverStatus.textContent = 'OFFLINE';
        driverStatus.classList.add('offline');
      }
    } else {
      toggleBtn.classList.remove('offline');
      toggleBtn.classList.add('available');
      toggleBtn.querySelector('.toggle-label').textContent = 'AVAILABLE';
      if (driverStatus) {
        driverStatus.textContent = 'AVAILABLE';
        driverStatus.classList.remove('offline');
      }
    }

    // TODO: Send status update to server
  });

  // Client-side logout
  document.getElementById('sidenav-logout-button')?.addEventListener('click', async function(e) {
    e.preventDefault();

    console.log('[DriverSidenav] Client-side logout initiated');

    const button = e.target;
    button.disabled = true;
    button.style.opacity = '0.6';

    try {
      const { logout } = await await import('../../lib/auth/auth-client');
      await logout();

      localStorage.clear();
      sessionStorage.clear();

      window.location.href = '/auth/login';
    } catch (error) {
      console.error('[DriverSidenav] Logout error:', error);
      window.location.href = '/auth/login';
    }
  });
</script>
