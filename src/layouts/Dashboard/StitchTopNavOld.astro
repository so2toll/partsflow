---
/**
 * Stitch Design System - Top Navigation Bar
 *
 * Dark top navigation bar with:
 * - Logo/Brand area (left)
 * - Navigation links (center)
 * - Search input
 * - Actions (New Project button, notifications, settings)
 * - User profile dropdown
 */

interface Props {
  userRole?: string;
  userId?: string;
  organization?: any;
}

const { userRole, userId, organization } = Astro.props;

const isSuperAdmin = userRole === "SuperAdmin";
---

<header class="fixed top-0 left-0 right-0 z-[1000] h-16 bg-[#121212] text-[#f1ffd2] text-sm font-sans">
  <div class="flex items-center justify-between w-full h-full px-12">
    <!-- Left: Brand -->
    <div class="flex items-center">
      <a href="/app/dashboard" class="flex items-center gap-3 text-decoration-none">
        <span class="material-symbols-outlined text-2xl text-[#f1ffd2]">auto_awesome</span>
        <span class="text-lg font-bold tracking-tight text-white">
          {isSuperAdmin ? "Studio AI" : organization ? organization.name : "Studio"}
        </span>
      </a>
    </div>

    <!-- Center: Navigation -->
    <nav class="hidden md:flex gap-8">
      <a href="/app/projects" class="text-[#f1ffd2] font-medium py-2 border-b-2 border-[#f1ffd2] opacity-90 hover:text-white hover:opacity-100 transition-all">Projects</a>
      <a href="/app/characters" class="text-[#f1ffd2] font-medium py-2 border-b-2 border-[#f1ffd2] opacity-90 hover:text-white hover:opacity-100 transition-all">Characters</a>
      <a href="/app/teams" class="text-[#f1ffd2] font-medium py-2 border-b-2 border-[#f1ffd2] opacity-90 hover:text-white hover:opacity-100 transition-all">Library</a>
      <a href="#" class="text-[#f1ffd2] font-medium py-2 border-b-2 border-[#f1ffd2] opacity-90 hover:text-white hover:opacity-100 transition-all">Workflows</a>
      <a href="#" class="text-[#f1ffd2] font-medium py-2 border-b-2 border-[#f1ffd2] opacity-90 hover:text-white hover:opacity-100 transition-all">Assets</a>
    </nav>

    <!-- Right: Search, Actions, User -->
    <div class="flex items-center gap-6">
      <!-- Search -->
      <div class="relative hidden lg:block">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#9ca3af] text-xl">search</span>
        <input
          type="text"
          placeholder="Search projects..."
          class="bg-[#1a1a1a] border-none rounded-full py-2 px-3 pl-10 text-xs text-[#e5e5e5] w-64 placeholder:text-[#9ca3af] focus:outline-none focus:ring-1 focus:ring-[#f1ffd2]"
        />
      </div>

      <!-- New Project Button -->
      <a
        href="/app/projects"
        class="hidden md:flex items-center gap-2 bg-[#dfff00] text-black border-none rounded-full py-2 px-4 text-sm font-medium hover:brightness-105 transition-filter cursor-pointer text-decoration-none"
      >
        <span class="material-symbols-outlined">add</span>
        <span>New Project</span>
      </a>

      <!-- Icons -->
      <div class="flex items-center gap-4">
        <button class="bg-transparent border-none p-0 cursor-pointer flex items-center justify-center text-[#f1ffd2] hover:text-white transition-colors">
          <span class="material-symbols-outlined">notifications</span>
        </button>
        <button class="bg-transparent border-none p-0 cursor-pointer flex items-center justify-center text-[#f1ffd2] hover:text-white transition-colors">
          <span class="material-symbols-outlined">settings</span>
        </button>

        <!-- User Avatar -->
        <div class="flex items-center">
          <div class="w-8 h-8 rounded-full overflow-hidden border-2 border-[#374151] bg-[#374151]">
            <img
              src="https://lh3.googleusercontent.com/a/default-user=l"
              alt="User"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
